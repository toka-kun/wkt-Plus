<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Image</title>
    <script src="/js/tailwindcss.js"></script>
    <link rel="stylesheet" href="/css/page.css">
</head>
<body class="bg-gray-900 font-sans min-h-screen flex flex-col m-0 p-0 overflow-hidden">
    
    <button class="back-button fixed top-5 left-5 z-50 bg-blue-500 hover:bg-blue-600 text-white font-semibold py-2 px-4 rounded-lg shadow-lg transform transition-all duration-300 ease-in-out flex items-center space-x-2" onclick="window.location.href='/tools'">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
        </svg>
        <span>戻る</span>
    </button>

    <div class="flex-grow w-full h-screen pt-20 pb-4 px-4 box-border flex flex-col gap-4">
        
        <div class="w-full flex gap-2">
            <input type="text" id="imageUrl" placeholder="画像のURLを入力してください" class="flex-grow p-3 rounded-xl bg-gray-800 text-white border border-gray-700 focus:outline-none focus:border-blue-500 shadow-lg">
            <button onclick="loadImage()" class="bg-blue-500 hover:bg-blue-600 text-white font-semibold py-3 px-6 rounded-xl shadow-lg transition-colors">
                表示
            </button>
        </div>

        <div class="w-full h-full rounded-2xl shadow-lg border-none bg-white flex items-center justify-center overflow-hidden relative">
            <span id="placeholder" class="text-gray-400 font-medium">ここに画像が表示されます</span>
            <img id="resultImage" class="max-w-full max-h-full object-contain hidden" alt="Proxy Image">
        </div>

    </div>

    <script>
        function loadImage() {
            const inputUrl = document.getElementById('imageUrl').value;
            
            // URLが空の場合は何もしない
            if (!inputUrl) return;

            // エンコードなしで指定の形式に結合
            const proxyUrl = "http://wsrv.nl/?url=" + inputUrl; 
            
            const imgElement = document.getElementById('resultImage');
            const placeholder = document.getElementById('placeholder');

            // 画像のURLを設定して表示、プレースホルダーを非表示
            imgElement.src = proxyUrl;
            imgElement.classList.remove('hidden');
            placeholder.classList.add('hidden');
        }

        // Enterキーを押したときの処理
        document.getElementById('imageUrl').addEventListener('keydown', function(event) {
            if (event.key === 'Enter') {
                event.preventDefault(); // 予期せぬページリロードを防ぐ
                loadImage();
            }
        });
    </script>

</body>
</html>
