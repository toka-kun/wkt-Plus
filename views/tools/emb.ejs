<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TH</title>
    <script src="/js/tailwindcss.js"></script>
    <link rel="stylesheet" href="/css/page.css">
</head>
<body class="bg-gray-900 font-sans min-h-screen flex flex-col m-0 p-0 overflow-hidden">
    
    <button class="back-button fixed top-5 left-5 z-50 bg-blue-500 hover:bg-blue-600 text-white font-semibold py-2 px-4 rounded-lg shadow-lg transform transition-all duration-300 ease-in-out flex items-center space-x-2" onclick="window.location.href='/tools'">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
        </svg>
        <span>戻る</span>
    </button>

    <button class="fixed top-5 right-5 z-50 bg-blue-500 hover:bg-blue-600 text-white font-semibold py-2 px-4 rounded-lg shadow-lg transform transition-all duration-300 ease-in-out flex items-center space-x-2" onclick="toggleFullScreen()">
        <svg id="icon-expand" xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8V4m0 0h4M4 4l5 5m11-1V4m0 0h-4m4 0l-5 5M4 16v4m0 0h4m-4 0l5-5m11 5l-5-5m5 5v-4m0 4h-4"></path>
        </svg>
        <svg id="icon-compress" xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 3v5H3 M8 8L3 3 M16 3v5h5 M16 8l5-5 M8 21v-5H3 M8 16l-5 5 M16 21v-5h5 M16 16l5 5"></path>
        </svg>
        <span id="fullscreen-text">全画面オン</span>
    </button>

    <div class="flex-grow w-full h-screen pt-20 pb-4 px-4 box-border">
        <iframe 
            id="content-frame"
            src="" 
            class="w-full h-full rounded-2xl shadow-lg border-none bg-white"
            allow="camera;microphone;geolocation;fullscreen"
            title="Embedded Content">
        </iframe>
    </div>

    <script>
        // --- 1. 全画面切り替えの処理 ---
        function toggleFullScreen() {
            // iframe要素を取得
            const iframe = document.getElementById('content-frame');
            
            if (!document.fullscreenElement) {
                // document.documentElement ではなく、iframe に対して requestFullscreen を実行
                iframe.requestFullscreen().catch((err) => {
                    console.error(`全画面表示の有効化中にエラーが発生しました: ${err.message}`);
                });
            } else {
                if (document.exitFullscreen) {
                    document.exitFullscreen();
                }
            }
        }

        // --- 2. 全画面状態の変更を検知してアイコンとテキストを切り替える ---
        document.addEventListener('fullscreenchange', () => {
            const iconExpand = document.getElementById('icon-expand');
            const iconCompress = document.getElementById('icon-compress');
            const btnText = document.getElementById('fullscreen-text');

            if (document.fullscreenElement) {
                // 全画面中の表示
                iconExpand.classList.add('hidden');
                iconCompress.classList.remove('hidden');
                btnText.textContent = '全画面オフ';
            } else {
                // 通常時の表示
                iconExpand.classList.remove('hidden');
                iconCompress.classList.add('hidden');
                btnText.textContent = '全画面オン';
            }
        });

        // --- 3. URLパラメーターに応じてiframeのURLを切り替える処理 ---
        document.addEventListener('DOMContentLoaded', () => {
            const urlParams = new URLSearchParams(window.location.search);
            const targetId = urlParams.get('id');

            const siteMap = {
                'blog': 'https://proxywiki.onrender.com',
                'dog': 'https://storage.googleapis.com/educationate/index.html',
                'brave': 'https://www.runapps.org/runcommunity/xbrave/create-brave.php',
                'and': 'https://appetize.io/embed/xc1w6f1krd589zhp22a0mgftyw?autoplay=false&amp;debug=true&amp;device=pixel4&amp;embed=true&amp;launchUrl=exp%3A%2F%2Fexp.host%2F%40snack%2Fsdk.46.0.0-ghV0%21Qgb8N&amp;scale=65&amp;screenOnly=false&amp;xDocMsg=true&amp;xdocMsg=true&amp;params=%7B&amp;osVersion=11.0&amp;deviceColor=black" style="border: none; margin: 0; height: 100vh; width: 100%;',
                'hel': '/tools/pro/hel',
                'gus': '/tools/pro/gus',
                'gusp': '/tools/pro/gusp',
                'rtem': '/tools/tool/rtem',
            };

            const iframe = document.getElementById('content-frame');

            if (targetId && siteMap[targetId]) {
                iframe.src = siteMap[targetId];
            } else {
                iframe.src = 'about:blank';
            }
        });
    </script>
</body>
</html>
