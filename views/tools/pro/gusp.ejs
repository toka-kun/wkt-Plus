    js('  Element.prototype.requestFullscreen=function(){');
    js('    if(!blocked){blocked=true;return Promise.resolve();}');
    js('    return orig.apply(this,arguments);');
    js('  };');
    js('})();');
  }
  if (rm.has('tab-drag')) {
    // The drag handler is an IIFE — there's no global to stub.
    // Instead we inject a capture-phase pointerdown listener that
    // intercepts any pointerdown on a .tab element and stops it
    // from propagating to GUST's drag handler, while still allowing
    // normal click/close events (which use click/pointerup, not pointerdown).
    js('(function(){');
    js('  document.addEventListener("pointerdown", function(e){');
    js('    if(e.button!==0) return;');
    js('    var tab=e.target.closest(".tab[data-tab-id]");');
    js('    if(!tab) return;');
    js('    if(e.target.closest(".tab-close")) return;');
    js('    // Stop GUST\'s drag listener from firing; click still works');
    js('    e.stopImmediatePropagation();');
