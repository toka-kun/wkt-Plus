function endPatcherTutorial() {
  const ov = document.getElementById('patcherTutorialOverlay');
  const card = document.getElementById('patcherTutorialCard');
  card.style.opacity = '0';
  card.style.transform = 'translateY(8px)';
  const bd = document.getElementById('patcherTutorialBackdrop');
  if (bd) bd.style.opacity = '0';
  const svg = document.getElementById('patcherTutorialSvg');
