  if (rm.has('metrics'))
    css('#metricsBtn,#metricsModal');

  // ---- JS overrides (flat lines only - no template literals, no backticks) ----
  if (rm.has('tutorial-include') || rm.has('tutorial-auto')) {
    js('window.startTutorial=function(){};');
    js('window.endTutorial=function(){};');
    js('window.__gustStartTutorial=function(){};');
