<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1"/>
<title>GUST Patcher</title>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;600&family=Space+Grotesk:wght@400;500;600;700&display=swap"/>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"/>
<style>
:root {
  --bg0: #0d0f12;
  --bg1: #181c21;
  --bg2: #1c2026;
  --bg3: #252b33;
  --bg-elevated: #161a1f;
  --main-bg: #13161a;
  --surface: rgba(255,255,255,.08);
  --surface2: rgba(255,255,255,.14);
  --bd: #4f5963;
  --bd2: #5a6370;
  --tx: #f0f4f8;
  --tx2: #b8c4d0;
  --tx3: #7d8a98;
  --ac: #9de5ff;
  --ac2: #70d4ff;
  --ok: #8aefb0;
  --warn: #f8dc75;
  --err: #ff9595;
  --radius-sm: 8px;
  --radius-md: 10px;
  --radius-lg: 20px;
  --radius-full: 9999px;
  --shadow-sm: 0 1px 3px rgba(0,0,0,.35);
  --shadow-md: 0 8px 24px rgba(0,0,0,.45);
  --ui: 'Space Grotesk','Segoe UI',sans-serif;
  --mono: 'JetBrains Mono','SF Mono',ui-monospace,monospace;
}
*{box-sizing:border-box;margin:0;padding:0}
html,body{height:100%;background:var(--bg0);color:var(--tx);font-family:var(--ui);overflow:hidden}
button,input,select,textarea{font:inherit}
::selection{background:rgba(141,217,255,.25);color:var(--tx)}
.app{height:100%;display:flex;flex-direction:column}

/* Titlebar */
.titlebar{display:flex;align-items:center;gap:12px;padding:8px 12px;background:var(--bg0);border-bottom:1px solid var(--bd);}
.brand{display:flex;align-items:center;gap:8px;color:var(--ac);font-weight:700;font-size:14px;white-space:nowrap;height:42px;padding:0 2px;}
.brand-letters{display:inline-flex;letter-spacing:3px;font-size:22px;font-weight:800;}
.brand-sub{font-size:22px;font-weight:800;color:var(--ac);margin-left:2px;letter-spacing:3px;}
.titlebar-actions{display:flex;align-items:center;gap:8px;margin-left:auto;}

/* GUST animations (exact copy) */
@keyframes gust-icon{0%{opacity:0;transform:translateX(-44px);filter:blur(8px)}65%{opacity:1;transform:translateX(4px);filter:blur(0)}100%{opacity:1;transform:translateX(0)}}
@keyframes gust-letter{0%{opacity:0;transform:translateX(-28px) skewX(-12deg);filter:blur(6px)}60%{opacity:1;transform:translateX(3px) skewX(2deg);filter:blur(0)}80%{transform:translateX(-1px) skewX(-.5deg)}100%{opacity:1;transform:translateX(0) skewX(0);filter:blur(0)}}
@keyframes gust-sub{0%{opacity:0;transform:translateY(4px)}100%{opacity:1;transform:translateY(0)}}
.gust-icon-anim{animation:gust-icon .7s cubic-bezier(.22,1,.36,1) both;animation-play-state:paused}
.gust-letter-G{animation:gust-letter .65s cubic-bezier(.22,1,.36,1) .10s both;animation-play-state:paused}
.gust-letter-U{animation:gust-letter .65s cubic-bezier(.22,1,.36,1) .20s both;animation-play-state:paused}
.gust-letter-S{animation:gust-letter .65s cubic-bezier(.22,1,.36,1) .30s both;animation-play-state:paused}
.gust-letter-T{animation:gust-letter .65s cubic-bezier(.22,1,.36,1) .40s both;animation-play-state:paused}
.gust-sub-anim{animation:gust-sub .45s ease-out .65s both;animation-play-state:paused}
.brand-anim-ready .gust-icon-anim,
.brand-anim-ready .gust-letter-G,
.brand-anim-ready .gust-letter-U,
.brand-anim-ready .gust-letter-S,
.brand-anim-ready .gust-letter-T,
.brand-anim-ready .gust-sub-anim{animation-play-state:running}

/* Buttons */
.btn-primary{display:flex;align-items:center;gap:7px;padding:0 16px;height:36px;background:var(--ac);color:#0b1015;font-weight:700;font-size:13px;border:none;border-radius:8px;cursor:pointer;transition:opacity .15s,transform .1s}
.btn-primary:hover{opacity:.85}
.btn-primary:active{transform:scale(.97)}
.btn-primary:disabled{opacity:.4;cursor:not-allowed;transform:none}
.btn-secondary{display:flex;align-items:center;gap:7px;padding:0 14px;height:36px;background:var(--bg2);color:var(--tx2);font-weight:500;font-size:13px;border:1px solid var(--bd);border-radius:8px;cursor:pointer;transition:background .12s,color .12s}
.btn-secondary:hover{background:var(--bg3);color:var(--tx)}

/* Layout */
.layout{flex:1;display:flex;overflow:hidden}

/* Sidebar — 200px wide, matching GUST exactly */
.sidebar{width:200px;min-width:200px;height:100%;background:rgba(13,15,18,.7);border-right:1px solid var(--bd);display:flex;flex-direction:column;backdrop-filter:blur(8px);overflow:hidden;}
.sidebar-scroll{flex:1;overflow-y:auto;overflow-x:hidden;padding:24px 0;}
.sidebar-scroll::-webkit-scrollbar{width:3px}
.sidebar-scroll::-webkit-scrollbar-track{background:transparent}
.sidebar-scroll::-webkit-scrollbar-thumb{background:var(--bd);border-radius:3px}
.sidebar nav{display:flex;flex-direction:column;gap:2px;padding:0 12px;}

/* Nav items — GUST values: padding 9px 14px, radius 8px, size 13px, tx3 */
.settings-nav-item{display:flex;align-items:center;gap:10px;padding:9px 14px;border-radius:8px;border:none;background:transparent;color:var(--tx3);font-size:13px;font-weight:500;font-family:var(--ui);cursor:pointer;text-align:left;width:100%;transition:background .12s,color .12s}
.settings-nav-item i{width:16px;text-align:center;font-size:13px;transition:color .12s}
.settings-nav-item:hover{background:var(--surface);color:var(--tx2)}
.settings-nav-item.active{background:rgba(157,229,255,.1);color:var(--ac)}
.settings-nav-item.active i{color:var(--ac)}
.nav-label{flex:1}

/* ── Sidebar icon micro-animations ── */
@keyframes _gust-pulse   { 0%,100%{transform:scale(1)}  50%{transform:scale(1.22)} }
@keyframes _gust-spin    { from{transform:rotate(0deg)} to{transform:rotate(360deg)} }
@keyframes _gust-spinrev { from{transform:rotate(0deg)} to{transform:rotate(-360deg)} }
@keyframes _gust-bob     { 0%,100%{transform:translateY(0)}  40%{transform:translateY(-4px)} 70%{transform:translateY(2px)} }
@keyframes _gust-shake   { 0%,100%{transform:rotate(0)}  20%{transform:rotate(-12deg)} 50%{transform:rotate(12deg)} 75%{transform:rotate(-7deg)} }
@keyframes _gust-ping    { 0%{transform:scale(1)} 40%{transform:scale(1.28)} 65%{transform:scale(.88)} 100%{transform:scale(1)} }
@keyframes _gust-tilt    { 0%,100%{transform:rotate(0deg)} 30%{transform:rotate(-14deg)} 70%{transform:rotate(10deg)} }
@keyframes _gust-pop     { 0%{transform:scale(1)} 35%{transform:scale(1.3)} 60%{transform:scale(.92)} 80%{transform:scale(1.08)} 100%{transform:scale(1)} }
@keyframes _gust-beam    { 0%,100%{transform:scaleX(1) scaleY(1)} 40%{transform:scaleX(1.2) scaleY(.85)} 70%{transform:scaleX(.9) scaleY(1.1)} }
@keyframes _gust-flick   { 0%,100%{transform:rotate(0) scale(1)} 25%{transform:rotate(-8deg) scale(1.15)} 60%{transform:rotate(6deg) scale(.95)} }
@keyframes _gust-jolt    { 0%,100%{transform:translateX(0)} 20%{transform:translateX(-4px)} 50%{transform:translateX(5px)} 75%{transform:translateX(-2px)} }
@keyframes _gust-stamp   { 0%{transform:scale(1) translateY(0)} 35%{transform:scale(.82) translateY(3px)} 65%{transform:scale(1.12) translateY(-2px)} 100%{transform:scale(1) translateY(0)} }
/* AI Assistant — wand: flick (magic tap) */
@keyframes _gust-wand-tap { 0%{transform:rotate(0) scale(1)} 25%{transform:rotate(-10deg) scale(1.15)} 60%{transform:rotate(8deg) scale(.95)} 100%{transform:rotate(0) scale(1)} }
.settings-nav-item[data-section="aiassistant"]:hover i { animation: _gust-wand-tap .35s ease-in-out forwards; }
/* Connection — wired: pulse like signal */
.settings-nav-item[data-section="connection"]:hover i { animation: _gust-pulse .55s cubic-bezier(.34,1.56,.64,1) forwards; }
/* Search — magnifying glass: bob */
.settings-nav-item[data-section="search"]:hover i { animation: _gust-bob .45s ease forwards; }
/* Privacy — shield: ping */
.settings-nav-item[data-section="privacy"]:hover i { animation: _gust-ping .4s ease forwards; }
/* Cache — database: beam (squish like stacking) */
.settings-nav-item[data-section="cache"]:hover i { animation: _gust-beam .45s ease forwards; }
/* Files & Media — film: shake (film reel clatter) */
.settings-nav-item[data-section="filesandmedia"]:hover i { animation: _gust-shake .45s ease forwards; }
/* Appearance — palette: spin */
.settings-nav-item[data-section="appearance"]:hover i { animation: _gust-spin .5s cubic-bezier(.34,1.56,.64,1) forwards; }
/* Home Screen — house: bob */
.settings-nav-item[data-section="homescreen"]:hover i { animation: _gust-bob .42s ease forwards; }
/* Shortcuts — keyboard: tilt (like pressing a key) */
.settings-nav-item[data-section="shortcuts"]:hover i { animation: _gust-tilt .4s ease forwards; }
/* Tutorial (Core) — map: pop */
.settings-nav-item[data-section="core-tutorial"]:hover i { animation: _gust-pop .45s ease forwards; }
/* Language — globe: spin reverse */
.settings-nav-item[data-section="language"]:hover i { animation: _gust-spinrev .5s cubic-bezier(.34,1.56,.64,1) forwards; }
/* Tab System — window-restore: flick (like flipping a tab) */
.settings-nav-item[data-section="core-tabs"]:hover i { animation: _gust-flick .4s ease forwards; }
/* Ad Blocker (Core) — shield: ping */
.settings-nav-item[data-section="core-adblock"]:hover i { animation: _gust-ping .4s ease forwards; }
/* Dev Tools — server: jolt (like a server rack vibrating) */
.settings-nav-item[data-section="core-devtools"]:hover i { animation: _gust-jolt .4s ease forwards; }
/* Metrics — chart: stamp (bars pressing down) */
.settings-nav-item[data-section="core-metrics"]:hover i { animation: _gust-stamp .45s ease forwards; }
/* Fallback — rotate-left: simple spin like reload button */
.settings-nav-item[data-section="fallback"]:hover i { transform: rotate(-180deg); transition: transform .35s cubic-bezier(.34,1.56,.64,1); }

/* #/# badge */
.nav-count{margin-left:auto;font-size:10px;font-weight:600;font-family:var(--mono);color:var(--tx3)}
.nav-count.lit{color:var(--ac)}

.sidebar-divider{border:none;border-top:1px solid var(--bd);margin:4px 4px;flex-shrink:0}
.sidebar-core-label{font-size:10px;font-weight:700;letter-spacing:.1em;color:var(--tx3);text-transform:uppercase;padding:8px 14px 4px;flex-shrink:0}

/* Main — GUST: padding 40px 48px, gap 32px */
.main{flex:1;overflow-y:auto;padding:40px 48px;display:flex;flex-direction:column;gap:32px;background:var(--main-bg)}
.main::-webkit-scrollbar{width:5px}
.main::-webkit-scrollbar-track{background:transparent}
.main::-webkit-scrollbar-thumb{background:var(--bd);border-radius:3px}

/* Settings sections — GUST: display none, flex-col, gap 16px */
.settings-section{display:none;flex-direction:column;gap:16px}
.settings-section.active{display:flex}

/* Settings card — GUST: bg2, bd, radius 12px */
.settings-card{background:var(--bg2);border:1px solid var(--bd);border-radius:12px;overflow:hidden}
/* Card head — GUST: padding 13px 18px, size 13px, weight 600, color tx, bg bg1 */
.settings-card-head{padding:13px 18px;font-size:13px;font-weight:600;color:var(--tx);background:var(--bg1);border-bottom:1px solid var(--bd);display:flex;align-items:center;gap:8px}
.settings-card-head i{color:var(--ac)}
/* Card body — GUST: padding 18px */
.settings-card-body{padding:18px}

/* GUST hint — 11px, tx3 */
.settings-hint{font-size:11px;color:var(--tx3);margin-top:6px;line-height:1.5}
/* GUST label — uppercase, 12px, tx3 */
.settings-label{font-size:12px;color:var(--tx3);margin-bottom:8px;display:block;text-transform:uppercase}

/* Patch rows */
.patch-row{display:flex;align-items:flex-start;justify-content:space-between;gap:16px;padding:10px 0}
.patch-row+.patch-row{border-top:1px solid var(--bd)}
.patch-row-info{flex:1;min-width:0}
.patch-row-label{font-size:13px;font-weight:500;color:var(--tx);margin-bottom:2px}
.patch-row-desc{font-size:11px;color:var(--tx3);line-height:1.5}
.broken-tag{font-size:10px;font-weight:700;color:#ff4444;margin-left:4px}

/* Checkbox — styled to match GUST's switch on/off feel */
.patch-check{width:22px;height:22px;border-radius:6px;border:2px solid var(--bd);background:var(--bg3);cursor:pointer;display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:1px;transition:border-color .15s,background .15s}
.patch-check.checked{border-color:var(--ac);background:rgba(157,229,255,.15)}
.patch-check.checked::after{content:'\f00c';font-family:'Font Awesome 6 Free';font-weight:900;font-size:11px;color:var(--ac)}
.patch-check.master-disabled{opacity:0.28;cursor:not-allowed;pointer-events:none;}
.patch-row.master-disabled{opacity:0.35;pointer-events:none;transition:opacity .18s;}
.settings-card.master-disabled{opacity:0.35;pointer-events:none;transition:opacity .18s;}

/* Sidebar master toggle bar */
.sidebar-master-bar{display:flex;align-items:center;gap:14px;padding:13px 18px;background:var(--bg2);border:2px solid var(--ac);border-radius:12px;margin-bottom:0;}
.sidebar-master-bar-icon{width:34px;height:34px;border-radius:9px;background:rgba(157,229,255,0.1);display:flex;align-items:center;justify-content:center;color:var(--ac);font-size:14px;flex-shrink:0;}
.sidebar-master-bar-info{flex:1;min-width:0;}
.sidebar-master-bar-label{font-size:13px;font-weight:700;color:var(--tx);margin-bottom:2px;}
.sidebar-master-bar-desc{font-size:11px;color:var(--tx3);line-height:1.4;}
.sidebar-master-check{width:24px;height:24px;border-radius:7px;border:2px solid rgba(157,229,255,0.35);background:rgba(157,229,255,0.06);cursor:pointer;display:flex;align-items:center;justify-content:center;flex-shrink:0;transition:border-color .15s,background .15s;}
.sidebar-master-check.checked{border-color:var(--ac);background:rgba(157,229,255,0.15);}
.sidebar-master-check.checked::after{content:'\f00c';font-family:'Font Awesome 6 Free';font-weight:900;font-size:12px;color:var(--ac);}

/* Section header */
.section-head{display:flex;align-items:center;justify-content:space-between;gap:8px;flex-wrap:wrap}
.section-title{font-size:18px;font-weight:700;color:var(--tx)}
.select-btns{display:flex;align-items:center;gap:6px}
.select-btn{font-size:11px;color:var(--ac);background:none;border:none;cursor:pointer;padding:2px 0;opacity:.65;transition:opacity .12s}
.select-btn:hover{opacity:1}
.select-sep{color:var(--bd2);font-size:10px}

/* Status bar */
.status-bar{padding:8px 16px;background:var(--bg-elevated);border-top:1px solid var(--bd);display:flex;align-items:center;gap:12px;font-size:12px;color:var(--tx3)}

/* Loading overlay */
.loading-overlay{position:fixed;inset:0;background:rgba(13,15,18,.88);backdrop-filter:blur(8px);z-index:9999;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:16px}
.loading-spinner{width:40px;height:40px;border:3px solid var(--bd);border-top-color:var(--ac);border-radius:50%;animation:spin .8s linear infinite}
@keyframes spin{to{transform:rotate(360deg)}}
.loading-text{font-size:14px;color:var(--tx2)}
.loading-sub{font-size:12px;color:var(--tx3)}

/* Error */
.error-box{background:rgba(255,149,149,.07);border:1px solid rgba(255,149,149,.25);border-radius:12px;padding:20px;display:flex;flex-direction:column;align-items:center;gap:10px;text-align:center}
.error-box i{font-size:28px;color:var(--err)}
.error-box h3{color:var(--err);font-size:14px}
.error-box p{color:var(--tx3);font-size:12px;line-height:1.6}

/* ── Homepage section ── */
.homepage-section{display:none;flex-direction:column;align-items:center;justify-content:flex-start;min-height:100%;width:100%}
.homepage-section.active{display:flex}
.homepage-hero{display:flex;flex-direction:column;align-items:center;justify-content:center;padding:80px 40px 28px;width:100%}
.homepage-brand-wrap{display:flex;align-items:center;gap:14px}
.hp-brand-letters{display:inline-flex;letter-spacing:5px;font-size:56px;font-weight:800;color:var(--ac)}
.hp-brand-sub{font-size:56px;font-weight:800;color:var(--ac);margin-left:4px;letter-spacing:4px}
.hp-icon{font-size:64px;color:var(--ac)}
.homepage-tagline{font-size:13px;font-weight:700;color:#ffffff;margin-top:10px;letter-spacing:0.04em}
.homepage-credits{display:flex;align-items:center;gap:6px;font-size:12px;color:var(--tx3);margin-top:16px}
.homepage-credits .heart{color:#f87171}
.homepage-credits strong{color:var(--tx2);font-weight:600}

.homepage-presets{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:18px;width:100%;max-width:720px;padding:0 40px 52px}
.preset-card{background:var(--bg2);border:1px solid var(--bd);border-radius:16px;overflow:hidden;display:flex;flex-direction:column;transition:border-color .18s,transform .15s,box-shadow .18s}
.preset-card:hover{border-color:var(--bd2);transform:translateY(-3px);box-shadow:0 16px 40px rgba(0,0,0,.5)}
.preset-card-head{padding:18px 20px 14px;background:var(--bg1);border-bottom:1px solid var(--bd);display:flex;align-items:center;gap:12px}
.preset-card-icon{width:40px;height:40px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:17px;flex-shrink:0}
.preset-card-icon.blue{background:rgba(157,229,255,.12);color:var(--ac)}
.preset-card-icon.green{background:rgba(138,239,176,.12);color:var(--ok)}
.preset-card-icon.amber{background:rgba(248,220,117,.12);color:var(--warn)}
.preset-card-title{font-size:15px;font-weight:700;color:var(--tx);line-height:1.2}
.preset-card-subtitle{font-size:11px;color:var(--tx3);margin-top:2px}
.preset-card-body{padding:16px 20px 12px;flex:1;display:flex;flex-direction:column;gap:5px}
.preset-card-desc{font-size:13px;color:var(--tx2);line-height:1.6;flex:1}
.preset-card-tags{display:flex;flex-wrap:wrap;gap:4px;margin-top:5px}
.preset-tag{font-size:10px;font-weight:600;padding:2px 7px;border-radius:99px;background:rgba(255,255,255,.06);color:var(--tx3);border:1px solid var(--bd)}
.preset-tag.ac{background:rgba(157,229,255,.1);color:var(--ac);border-color:rgba(157,229,255,.2)}
.preset-tag.ok{background:rgba(138,239,176,.1);color:var(--ok);border-color:rgba(138,239,176,.2)}
.preset-tag.warn{background:rgba(248,220,117,.1);color:var(--warn);border-color:rgba(248,220,117,.2)}
.preset-card-footer{padding:12px 20px 18px}
.preset-dl-btn{display:flex;align-items:center;justify-content:center;gap:7px;width:100%;padding:0;height:38px;border-radius:9px;font-weight:700;font-size:13px;border:none;cursor:pointer;transition:opacity .15s,transform .1s;font-family:var(--ui);margin-bottom:6px}
.preset-dl-btn.primary{background:var(--ac);color:#0b1015}
.preset-dl-btn.secondary{background:var(--bg3);color:var(--tx2);border:1px solid var(--bd)}
.preset-dl-btn:hover{opacity:.85}
.preset-dl-btn:active{transform:scale(.97)}
.preset-dl-btn:disabled{opacity:.4;cursor:not-allowed;transform:none}
.preset-source-note{font-size:10px;color:var(--tx3);text-align:center;display:flex;align-items:center;justify-content:center;gap:4px}
.recommended-badge{display:inline-flex;align-items:center;gap:4px;font-size:10px;font-weight:700;padding:2px 8px;border-radius:99px;background:rgba(157,229,255,.13);color:var(--ac);border:1px solid rgba(157,229,255,.35);letter-spacing:.04em;text-transform:uppercase;}

/* Tutorial overlay */
#patcherTutorialOverlay{position:fixed;inset:0;z-index:99999;pointer-events:all;display:none}
#patcherTutorialBackdrop{position:absolute;inset:0;backdrop-filter:blur(10px);-webkit-backdrop-filter:blur(10px);transition:opacity .35s;opacity:0;pointer-events:all}
#patcherTutorialSvg{position:absolute;inset:0;width:100%;height:100%;pointer-events:all;transition:opacity .35s;opacity:0}
#patcherTutorialCard{position:absolute;width:360px;background:var(--bg2);border:1px solid var(--ac);border-radius:16px;padding:24px 26px 20px;box-shadow:0 12px 50px rgba(0,0,0,.7),0 0 0 1px rgba(100,210,255,.08);pointer-events:all;transition:opacity .25s,transform .25s;opacity:0;transform:translateY(8px);z-index:10}
#patcherTutorialArrow{position:absolute;width:12px;height:12px;background:var(--bg2);border:1px solid var(--ac);display:none;transform:rotate(45deg);z-index:-1}
#patcherTutorialRing{position:absolute;pointer-events:none;border:1.5px solid #9de5ff;border-radius:8px;display:none;z-index:3}
</style>
</head>
<body>
<div class="app">

<div class="loading-overlay" id="loadingOverlay">
  <div class="loading-spinner"></div>
  <div class="loading-text">Fetching GUST source…</div>
  <div class="loading-sub" id="loadingSub">Connecting…</div>
</div>

<div class="titlebar">
  <div class="brand">
    <i class="fas fa-wind gust-icon-anim" style="font-size:18px"></i>
    <span class="brand-letters"><span class="gust-letter-G">G</span><span class="gust-letter-U">U</span><span class="gust-letter-S">S</span><span class="gust-letter-T">T</span></span>
    <span class="brand-sub gust-sub-anim">Patcher</span>
  </div>
  <div style="display:flex;align-items:center;gap:5px;font-size:13px;font-weight:700;color:#ffffff;margin-left:-4px;white-space:nowrap;position:relative;top:3px;">Made with <i class="fas fa-heart" style="color:#f87171;font-size:12px;margin:0 2px;"></i> by <strong style="font-weight:700;">Nautilus Labs</strong></div>
