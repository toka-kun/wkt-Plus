  if (rm.has('metrics'))       stubFns(['showMetrics','hideMetrics']);

  // ---- Assemble payload and base64-encode it ----
  // The payload is encoded so that no special characters (backticks, <\/script>,
  // quotes, em-dashes) can break the surrounding HTML or script context.
  if (!lsLines.length && !cssRules.length && !jsLines.length) return '';

  var parts = ['(function(){'];
  if (lsLines.length) { parts.push('// localStorage pre-seeds'); lsLines.forEach(function(l){ parts.push(l); }); }
  if (cssRules.length) {
    parts.push('// CSS hide rules');
    parts.push('var _s=document.createElement("style");');
    parts.push('_s.id="gust-patcher-css";');
    parts.push('_s.textContent=' + JSON.stringify(cssRules.join('\n')) + ';');
    parts.push('(document.head||document.documentElement).appendChild(_s);');
  }
  if (jsLines.length) {
    parts.push('// JS overrides');
    parts.push('function _gp(){');
    jsLines.forEach(function(l){ parts.push('  ' + l); });
    parts.push('}');
    parts.push('if(document.readyState==="loading"){document.addEventListener("DOMContentLoaded",_gp);}else{_gp();}');
  }
  parts.push('})();');
  var payload = parts.join('\n');

  // btoa only handles latin1; encode utf8 first via encodeURIComponent/unescape trick
  var b64 = btoa(unescape(encodeURIComponent(payload)));

  // Bootstrap: only contains the b64 blob (alphanumeric+/+=) and safe method names.
  // Uses <\/script> so the HTML parser never sees a raw <\/script> closing tag.
  var out = '';
  out += '<!-- GUST Patcher patch -->\n';
  out += '<script>\n';
  out += '(function(){\n';
  out += '  var b=' + JSON.stringify(b64) + ';\n';
  out += '  var c=decodeURIComponent(escape(atob(b)));\n';
  out += '  try{new Function(c)();}catch(e){console.error("[GUST Patcher] patch failed:",e);}\n';
  out += '})();\n';
  out += '<\/script>';
  return '\n' + out + '\n';
}

function buildAndDownload() {
  setStatus('info', 'Building patched GUST...');

  const removed = [
    ...[...document.querySelectorAll('.patch-check[data-patch]')]
      .filter(e => !e.classList.contains('checked'))
      .map(e => e.dataset.patch),
    ...[...document.querySelectorAll('.sidebar-master-check[data-patch]')]
      .filter(e => !e.classList.contains('checked'))
      .map(e => e.dataset.patch)
  ];

  let html = sourceHTML;

  // Inject patch script right before </head>
  const patchScript = buildPatchScript(removed);
  if (patchScript) {
    // Try </head> first, fall back to first <script> tag
    if (html.includes('</head>')) {
      html = html.replace('</head>', patchScript + '</head>');
    } else {
      const firstScript = html.indexOf('<script');
      if (firstScript !== -1) {
        html = html.slice(0, firstScript) + patchScript + html.slice(firstScript);
      }
    }
  }

  // Stamp a build comment
  var stamp = removed.length
    ? '<!-- GUST Patcher build ' + new Date().toISOString() + ' removed: ' + removed.join(', ') + ' -->'
    : '<!-- GUST Patcher build ' + new Date().toISOString() + ' full default build -->';
  html = html.replace(/<!doctype html>/i, '<!doctype html>\n' + stamp);

  const blob = new Blob([html], {type:'text/html'});
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = 'GUST-Patched.html';
  document.body.appendChild(a);
  a.click();
  document.body.removeChild(a);
  setTimeout(() => URL.revokeObjectURL(a.href), 5000);
  var kb = (html.length/1024).toFixed(0);
  var msg = removed.length ? ('Downloaded GUST-Patched.html - ' + kb + ' KB (' + removed.length + ' patch' + (removed.length>1?'es':'') + ' applied)') : ('Downloaded GUST-Patched.html - ' + kb + ' KB');
  setStatus('ok', msg);
  const fsc = document.getElementById('fileSizeCount');
  if (fsc) { fsc.textContent = kb + ' KB'; }
  const fsw = document.getElementById('fileSizeWrap');
  if (fsw) { fsw.style.display = 'flex'; fsw.style.alignItems = 'center'; fsw.style.gap = '6px'; }
}

