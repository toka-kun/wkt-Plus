  card.style.transform = 'translateY(6px)';

  dots.innerHTML = patcherTutSteps.map((_,i) =>
    `<div style="width:${i===idx?'16px':'6px'};height:6px;border-radius:3px;background:${i===idx?'var(--ac)':'rgba(255,255,255,0.2)'};transition:all .2s;"></div>`
  ).join('');

  titleEl.innerHTML = step.title;
  bodyEl.innerHTML = step.body;
  iconEl.innerHTML = step.icon;
  btnNext.innerHTML = idx === patcherTutSteps.length-1 ? '<i class="fas fa-check" style="margin-right:5px;"></i>Done' : 'Next <i class="fas fa-arrow-right" style="margin-left:5px;"></i>';
  btnBack.style.display = idx > 0 ? 'block' : 'none';

  // Run any pre-step navigation hook
  if (step.onBefore) step.onBefore();

  const _delay = step.navDelay || 80;
  setTimeout(() => {
    const sr = document.getElementById('patcherSpotRect');
    if (cloneWrap) cloneWrap.innerHTML = '';

    if (step.target || step.getBounds) {
      const r = step.getBounds ? step.getBounds() : (() => { const el = document.querySelector(step.target); return el ? el.getBoundingClientRect() : null; })();
      if (r) {
        const pad = step.pad !== undefined ? step.pad : 6;

        // SVG cutout
        sr.setAttribute('x', r.left - pad);
        sr.setAttribute('y', r.top - pad);
        sr.setAttribute('width', r.width + pad*2);
        sr.setAttribute('height', r.height + pad*2);
        sr.setAttribute('rx', pad > 10 ? '20' : '10');

        // Ring overlay
        ringDiv.style.left = (r.left-pad)+'px';
        ringDiv.style.top = (r.top-pad)+'px';
        ringDiv.style.width = (r.width+pad*2)+'px';
        ringDiv.style.height = (r.height+pad*2)+'px';
        ringDiv.style.borderRadius = (pad > 10 ? '20px' : '10px');
        ringDiv.style.display = 'block';

        // Clone the element and place it on top of the blur
        const cloneSourceEl = step.target ? document.querySelector(step.target) : null;
        if (cloneWrap && cloneSourceEl) {
          try {
            const clone = cloneSourceEl.cloneNode(true);
            clone.removeAttribute('id');
            const computedBR = getComputedStyle(cloneSourceEl).borderRadius || '0px';
            clone.style.cssText = '';
            clone.style.position = 'absolute';
            clone.style.left = r.left + 'px';
            clone.style.top = r.top + 'px';
            clone.style.width = r.width + 'px';
            clone.style.height = r.height + 'px';
            clone.style.margin = '0';
            clone.style.pointerEvents = 'none';
            clone.style.boxSizing = 'border-box';
            clone.style.borderRadius = computedBR;
            clone.style.overflow = 'hidden';
            clone.style.transform = 'none';
            clone.style.animation = 'none';
            clone.style.transition = 'none';
            clone.style.filter = 'none';
            clone.style.backdropFilter = 'none';
            clone.style.webkitBackdropFilter = 'none';
            clone.style.boxShadow = 'none';
            clone.style.opacity = '1';
            clone.style.zIndex = '2';
            // preserve the original background so the clone looks right
            clone.style.background = getComputedStyle(cloneSourceEl).background;
            // preserve flex layout so button contents stay centered
            const cs = getComputedStyle(cloneSourceEl);
            if (cs.display === 'flex' || cs.display === 'inline-flex') {
              clone.style.display = cs.display;
              clone.style.alignItems = cs.alignItems;
              clone.style.justifyContent = cs.justifyContent;
              clone.style.gap = cs.gap;
            }
            cloneWrap.appendChild(clone);
          } catch(e) {}
        } else if (cloneWrap && step.getBounds) {
          // For getBounds steps, clone each source element individually
          const cloneTargets = step.cloneSelector ? document.querySelectorAll(step.cloneSelector) : [];
          cloneTargets.forEach(srcEl => {
            try {
              const er = srcEl.getBoundingClientRect();
              const clone = srcEl.cloneNode(true);
              clone.removeAttribute('id');
              clone.querySelectorAll('[id]').forEach(c => c.removeAttribute('id'));
              clone.style.cssText = '';
              clone.style.position = 'absolute';
              clone.style.left = er.left + 'px';
              clone.style.top = er.top + 'px';
              clone.style.width = er.width + 'px';
              clone.style.height = er.height + 'px';
              clone.style.margin = '0';
              clone.style.pointerEvents = 'none';
              clone.style.boxSizing = 'border-box';
              clone.style.borderRadius = getComputedStyle(srcEl).borderRadius || '0px';
              clone.style.overflow = 'hidden';
              clone.style.transform = 'none';
              clone.style.animation = 'none';
              clone.style.transition = 'none';
              clone.style.filter = 'none';
              clone.style.backdropFilter = 'none';
              clone.style.webkitBackdropFilter = 'none';
              clone.style.boxShadow = 'none';
              clone.style.opacity = '1';
              clone.style.zIndex = '2';
              clone.style.background = getComputedStyle(srcEl).background;
              const cs = getComputedStyle(srcEl);
              if (cs.display === 'flex' || cs.display === 'inline-flex') {
                clone.style.display = cs.display;
                clone.style.flexDirection = cs.flexDirection;
                clone.style.alignItems = cs.alignItems;
                clone.style.justifyContent = cs.justifyContent;
              }
              cloneWrap.appendChild(clone);
            } catch(e) {}
          });
        }

        if (svgEl) svgEl.style.opacity = '1';
        if (so) { so.setAttribute('mask','url(#patcherSpotMask)'); so.style.display=''; }
        document.getElementById('patcherTutorialBackdrop').style.background = '';

        patcherPositionCard(card, arrow, r, step.pos);
      } else {
        sr.setAttribute('width','0'); sr.setAttribute('height','0');
        ringDiv.style.display = 'none';
        patcherCenterCard(card, arrow);
      }
    } else {
      sr.setAttribute('width','0'); sr.setAttribute('height','0');
      ringDiv.style.display = 'none';
      if (svgEl) svgEl.style.opacity = '0';
      document.getElementById('patcherTutorialBackdrop').style.background = 'rgba(0,0,0,0.48)';
      patcherCenterCard(card, arrow);
    }

    requestAnimationFrame(() => requestAnimationFrame(() => {
      card.style.opacity = '1';
      card.style.transform = 'translateY(0)';
    }));
  }, _delay);
}

function patcherPositionCard(card, arrow, r, pos) {
  const cw = 360;
  const vw = window.innerWidth, vh = window.innerHeight;
  const pad = 16;
  arrow.style.display = 'none';
  card.style.borderRadius = '16px';

  function placeArrowBelow(cardLeft, cardTop, cardH) {
    // Arrow pointing up from card toward the target above
    const cx = r.left + r.width / 2;
    const nubMin = 24, nubMax = cw - 24;
    const rawNub = cx - cardLeft - 6;
    arrow.style.left = Math.min(Math.max(rawNub, nubMin), nubMax) + 'px';
    arrow.style.right = '';
    // card is below target -> arrow points up (top nub)
    if (cardTop >= r.bottom - 4) {
      arrow.style.top = '-7px'; arrow.style.bottom = '';
      arrow.style.borderBottom = 'none'; arrow.style.borderRight = 'none';
      arrow.style.borderTop = '1px solid var(--ac)'; arrow.style.borderLeft = '1px solid var(--ac)';
    } else {
      // card flipped above -> arrow points down
      arrow.style.bottom = '-7px'; arrow.style.top = '';
      arrow.style.borderTop = 'none'; arrow.style.borderLeft = 'none';
      arrow.style.borderBottom = '1px solid var(--ac)'; arrow.style.borderRight = '1px solid var(--ac)';
    }
    arrow.style.display = 'block';
  }

  if (pos === 'above') {
    const cardH = card.offsetHeight || 220;
    let left = Math.max(pad, r.left + r.width/2 - cw/2);
    left = Math.min(left, vw - cw - pad);
    let top = r.top - cardH - 26;
    if (top < pad) top = r.bottom + 26; // flip below if no room
    top = Math.max(pad, top);
    card.style.left = left+'px'; card.style.top = top+'px';
    card.style.bottom = ''; card.style.right = '';
    // Arrow points down toward target below
    const cx = r.left + r.width / 2;
    const nubMin = 24, nubMax = cw - 24;
    const rawNub = cx - left - 6;
    arrow.style.left = Math.min(Math.max(rawNub, nubMin), nubMax) + 'px';
    arrow.style.right = '';
    arrow.style.bottom = '-7px'; arrow.style.top = '';
    arrow.style.borderTop = 'none'; arrow.style.borderLeft = 'none';
    arrow.style.borderBottom = '1px solid var(--ac)'; arrow.style.borderRight = '1px solid var(--ac)';
    arrow.style.display = 'block';

  } else if (pos === 'below' || pos === 'below-left') {
    let left = pos === 'below-left'
      ? Math.max(pad, r.right - cw)
      : Math.max(pad, r.left + r.width/2 - cw/2);
    left = Math.min(left, vw - cw - pad);
    let top = r.bottom + 26;
    const cardH = card.offsetHeight || 220;
    if (top + cardH + pad > vh) top = Math.max(pad, r.top - cardH - 26);
    top = Math.max(pad, top);
    card.style.left = left+'px'; card.style.top = top+'px';
    card.style.bottom = ''; card.style.right = '';
    placeArrowBelow(left, top, cardH);

  } else if (pos === 'right') {
    // Card placed to the right of the target, arrow points left toward the target
    let left = r.right + 28;
    const cardH = card.offsetHeight || 240;
    // If no room on right, flip to left
    if (left + cw + pad > vw) left = Math.max(pad, r.left - cw - 28);
    let top = Math.max(pad, r.top + r.height/2 - cardH/2);
    top = Math.min(top, vh - cardH - pad);
    card.style.left = left+'px'; card.style.top = top+'px';
    card.style.bottom = ''; card.style.right = '';

    // Vertical nub position on the card (points horizontally toward target)
    const cy = r.top + r.height/2;
    const nubMin = 20, nubMax = (cardH || 240) - 20;
    const rawNub = cy - top - 6;
    const nubPos = Math.min(Math.max(rawNub, nubMin), nubMax);

    arrow.style.top = nubPos + 'px';
    arrow.style.bottom = '';
    if (left >= r.right) {
      // card is to the right -> arrow nub on left side
      arrow.style.left = '-7px'; arrow.style.right = '';
      arrow.style.borderTop = 'none'; arrow.style.borderRight = 'none';
      arrow.style.borderBottom = '1px solid var(--ac)'; arrow.style.borderLeft = '1px solid var(--ac)';
    } else {
      // card flipped to left -> arrow nub on right side
      arrow.style.right = '-7px'; arrow.style.left = '';
      arrow.style.borderBottom = 'none'; arrow.style.borderLeft = 'none';
      arrow.style.borderTop = '1px solid var(--ac)'; arrow.style.borderRight = '1px solid var(--ac)';
    }
    arrow.style.display = 'block';
  } else {
    patcherCenterCard(card, arrow);
  }
}

function patcherCenterCard(card, arrow) {
  const vw = window.innerWidth, vh = window.innerHeight;
  card.style.left = (vw/2 - 180)+'px';
  card.style.top = (vh/2 - 100)+'px';
  card.style.bottom = ''; card.style.right = '';
  if (arrow) arrow.style.display = 'none';
}

document.getElementById('patcherTutorialNext').addEventListener('click', () => {
  if (patcherTutIdx < patcherTutSteps.length-1) {
    patcherTutIdx++;
    showPatcherTutStep(patcherTutIdx);
  } else {
    endPatcherTutorial();
  }
});
document.getElementById('patcherTutorialBack').addEventListener('click', () => {
  if (patcherTutIdx > 0) { patcherTutIdx--; showPatcherTutStep(patcherTutIdx); }
});
document.getElementById('patcherTutorialSkip').addEventListener('click', endPatcherTutorial);

// ── Preset downloads ──
function downloadBaseGUST() {
  if (sourceLoaded && sourceHTML) {
    triggerDownload(sourceHTML, 'GUST.html');
    return;
  }
  // Source not loaded yet — fetch directly
  const btn = document.getElementById('presetBaseBtn');
  if (btn) { btn.disabled = true; btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Fetching…'; }
  fetch('https://cdn.jsdelivr.net/gh/nautilus-os/GUST@main/index.html', {cache:'no-store'})
    .then(r => { if (!r.ok) throw new Error('HTTP '+r.status); return r.text(); })
    .then(text => { triggerDownload(text, 'GUST.html'); })
    .catch(() => { window.open('https://github.com/nautilus-os/GUST/raw/refs/heads/main/index.html','_blank'); })
    .finally(() => { if (btn) { btn.disabled = false; btn.innerHTML = '<i class="fas fa-download"></i> Download Base GUST'; } });
}

const LITE_PATCHES = [
  'threads','webrtc-block','media-headers',
  'spellcheck','search-favicon','ua-request','ua-page',
  'dev-logs','dev-inspector','metrics','language'
];

function downloadLite() {
  if (!sourceLoaded || !sourceHTML) {
    alert('Source not loaded yet.');
    return;
  }
  const saved = {};
  document.querySelectorAll('.patch-check[data-patch]').forEach(el => {
    saved[el.dataset.patch] = el.classList.contains('checked');
  });
  document.querySelectorAll('.patch-check[data-patch]').forEach(el => {
    el.classList.toggle('checked', LITE_PATCHES.includes(el.dataset.patch));
  });
  const removed = [
    ...[...document.querySelectorAll('.patch-check[data-patch]')]
      .filter(e => !e.classList.contains('checked'))
      .map(e => e.dataset.patch),
    ...[...document.querySelectorAll('.sidebar-master-check[data-patch]')]
      .filter(e => !e.classList.contains('checked'))
      .map(e => e.dataset.patch)
  ];
  let html = sourceHTML;
  const patchScript = buildPatchScript(removed);
  if (patchScript) {
    if (html.includes('</head>')) {
      html = html.replace('</head>', patchScript + '</head>');
    } else {
      const firstScript = html.indexOf('<script');
      if (firstScript !== -1) html = html.slice(0, firstScript) + patchScript + html.slice(firstScript);
    }
  }
  const stamp = '<!-- GUST Patcher preset:lite build ' + new Date().toISOString() + ' -->';
  html = html.replace(/<!doctype html>/i, '<!doctype html>\n' + stamp);
  document.querySelectorAll('.patch-check[data-patch]').forEach(el => {
    el.classList.toggle('checked', saved[el.dataset.patch]);
  });
  updateCounts();
  triggerDownload(html, 'GUST-Lite.html');
}

function triggerDownload(content, filename) {
  const blob = new Blob([content], {type:'text/html'});
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url; a.download = filename;
  document.body.appendChild(a); a.click();
  document.body.removeChild(a);
  setTimeout(() => URL.revokeObjectURL(url), 2000);
}

function updatePresetButtons() {
  const can = sourceLoaded && !!sourceHTML;
  const s = document.getElementById('presetLiteBtn');
  if (s) s.disabled = !can;
}

fetchSource();
updateCounts();
// Initialize master switch child dimming on load
document.querySelectorAll('.patch-check[data-master-for]').forEach(master => {
  applyMasterState(master, master.classList.contains('checked'));
});
</script>
