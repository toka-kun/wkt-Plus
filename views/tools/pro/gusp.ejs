<div id="patcherTutorialOverlay">
  <div id="patcherTutorialBackdrop"></div>
  <svg id="patcherTutorialSvg" xmlns="http://www.w3.org/2000/svg">
    <defs>
      <mask id="patcherSpotMask">
        <rect width="100%" height="100%" fill="white"/>
        <rect id="patcherSpotRect" x="0" y="0" width="0" height="0" rx="12" fill="black"/>
      </mask>
    </defs>
    <rect width="100%" height="100%" fill="rgba(0,0,0,0.48)" mask="url(#patcherSpotMask)" id="patcherSpotOverlay"/>
    <rect id="patcherSpotRing" x="0" y="0" width="0" height="0" rx="12" fill="none" stroke="var(--ac)" stroke-width="1"/>
  </svg>
  <div id="patcherTutorialRing"></div>
  <div id="patcherTutorialCloneWrap" style="position:absolute;inset:0;pointer-events:none;z-index:2;"></div>
  <div id="patcherTutorialCard">
    <div id="patcherTutorialDots" style="display:flex;gap:5px;margin-bottom:16px;"></div>
    <div id="patcherTutorialArrow"></div>
    <div style="display:flex;align-items:flex-start;gap:14px;margin-bottom:14px;">
      <div id="patcherTutorialIcon" style="width:42px;height:42px;border-radius:11px;background:rgba(100,210,255,.12);display:flex;align-items:center;justify-content:center;flex-shrink:0;color:var(--ac);font-size:18px;"></div>
      <div style="flex:1;">
        <div id="patcherTutorialTitle" style="font-size:15px;font-weight:700;color:var(--tx);margin-bottom:5px;line-height:1.2;"></div>
        <div id="patcherTutorialBody" style="font-size:13.5px;color:var(--tx2);line-height:1.6;"></div>
      </div>
    </div>
    <div style="display:flex;justify-content:space-between;align-items:center;margin-top:18px;">
      <button id="patcherTutorialSkip" style="background:none;border:none;color:var(--tx3);font-size:12px;cursor:pointer;padding:0;">Skip tour</button>
      <div style="display:flex;gap:8px;">
        <button id="patcherTutorialBack" style="background:var(--bg3);border:1px solid var(--bd);color:var(--tx2);border-radius:8px;padding:7px 18px;font-size:13px;cursor:pointer;display:none;font-family:var(--ui)"><i class="fas fa-arrow-left" style="margin-right:5px;"></i>Back</button>
        <button id="patcherTutorialNext" style="background:var(--ac);border:none;color:#000;border-radius:8px;padding:7px 20px;font-size:13px;font-weight:700;cursor:pointer;font-family:var(--ui)">Next</button>
      </div>
    </div>
  </div>
</div>

</div>
<script>
let sourceHTML = '', sourceLoaded = false;
const RAW_URL = 'https://raw.githubusercontent.com/nautilus-os/GUST/refs/heads/main/index.html';
const GH_URL  = 'https://github.com/nautilus-os/GUST/raw/refs/heads/main/index.html';

// Default checked state for all patches (all checked by default)
function resetCheckboxesToDefault() {
  document.querySelectorAll('.patch-check[data-patch]').forEach(el => {
    el.classList.add('checked');
    el.classList.remove('master-disabled');
    delete el.dataset.savedCheckedBySidebar;
  });
  document.querySelectorAll('.sidebar-master-check[data-patch]').forEach(el => {
    el.classList.add('checked');
  });
  // Re-apply master states after reset
  document.querySelectorAll('.settings-card').forEach(c => c.classList.remove('master-disabled'));
  updateCounts();
}

function playBrandAnimation() {
  const brand = document.querySelector('.brand');
  brand.classList.remove('brand-anim-ready');
  const animated = brand.querySelectorAll('.gust-icon-anim, .gust-letter-G, .gust-letter-U, .gust-letter-S, .gust-letter-T, .gust-sub-anim');
  animated.forEach(el => { el.style.animation = 'none'; el.style.opacity = '0'; });
  void brand.offsetWidth;
  animated.forEach(el => { el.style.animation = ''; el.style.opacity = ''; });
  void brand.offsetWidth;
  brand.classList.add('brand-anim-ready');

  // Also replay homepage brand animation
  const hpWrap = document.querySelector('.homepage-brand-wrap');
  if (hpWrap) {
    hpWrap.classList.remove('brand-anim-ready');
    const hpAnimated = hpWrap.querySelectorAll('.gust-icon-anim, .gust-letter-G, .gust-letter-U, .gust-letter-S, .gust-letter-T, .gust-sub-anim');
    hpAnimated.forEach(el => { el.style.animation = 'none'; el.style.opacity = '0'; });
    void hpWrap.offsetWidth;
    hpAnimated.forEach(el => { el.style.animation = ''; el.style.opacity = ''; });
    void hpWrap.offsetWidth;
    hpWrap.classList.add('brand-anim-ready');
  }
}

function updateCounts() {
  const all = document.querySelectorAll('.patch-check[data-section]');
  let totalOn = 0, totalAll = 0;
  const map = {};
  all.forEach(el => {
    const s = el.dataset.section;
    if (!map[s]) map[s] = {on:0,total:0};
    map[s].total++; totalAll++;
    if (el.classList.contains('checked')) { map[s].on++; totalOn++; }
  });
  // Also count sidebar master bars
  document.querySelectorAll('.sidebar-master-check[data-section]').forEach(el => {
    const s = el.dataset.section;
    if (!map[s]) map[s] = {on:0,total:0};
    map[s].total++; totalAll++;
    if (el.classList.contains('checked')) { map[s].on++; totalOn++; }
  });
  Object.keys(map).forEach(s => {
    const b = document.getElementById('nc-' + s);
    if (!b) return;
    b.textContent = map[s].on + '/' + map[s].total;
    b.classList.toggle('lit', map[s].on > 0);
  });
  document.getElementById('totalCount').textContent = totalOn + '/' + totalAll;
  const removed = totalAll - totalOn;
  const rc = document.getElementById('removedCount');
  if (rc) { rc.textContent = removed; rc.style.color = removed > 0 ? 'var(--warn)' : 'var(--tx3)'; }
  const dlBtn = document.getElementById('downloadBtn');
  if (dlBtn && sourceLoaded) {
    dlBtn.disabled = removed === 0;
    dlBtn.title = removed === 0 ? 'Please apply a patch' : '';
  }
}

function applyMasterState(masterPatch, isChecked) {
  const masterKey = masterPatch.dataset.patch;
  const children = (masterPatch.dataset.masterFor || '').split(' ').filter(Boolean);

  // Dim/undim child cards
  document.querySelectorAll(`[data-child-of="${masterKey}"]`).forEach(el => {
    el.classList.toggle('master-disabled', !isChecked);
  });

  children.forEach(childPatch => {
    document.querySelectorAll(`.patch-check[data-patch="${childPatch}"]`).forEach(el => {
      if (!isChecked) {
        // Save current checked state before disabling, then uncheck
        el.dataset.savedChecked = el.classList.contains('checked') ? '1' : '0';
        el.classList.remove('checked');
        el.classList.add('master-disabled');
      } else {
        el.classList.remove('master-disabled');
        // Restore previously saved state (default to checked if no saved state)
        const saved = el.dataset.savedChecked;
        if (saved === '0') {
          el.classList.remove('checked');
        } else {
          el.classList.add('checked');
        }
        delete el.dataset.savedChecked;
      }
    });
  });
}

function togglePatch(el) {
  // Don't toggle children of a disabled master
  if (el.classList.contains('master-disabled')) return;
  const wasChecked = el.classList.contains('checked');
  el.classList.toggle('checked');
  const isChecked = el.classList.contains('checked');
  // If this is a master, cascade to children
  if (el.dataset.masterFor) applyMasterState(el, isChecked);
  updateCounts();
}

function toggleSidebarMaster(el) {
  el.classList.toggle('checked');
  const isChecked = el.classList.contains('checked');
  const children = (el.dataset.masterFor || '').split(' ').filter(Boolean);

  // Dim/enable all settings cards and patch rows in this section
  const section = el.closest('.settings-section');
  if (section) {
    section.querySelectorAll('.settings-card').forEach(card => {
      card.classList.toggle('master-disabled', !isChecked);
    });
    section.querySelectorAll('.patch-check').forEach(check => {
      if (!isChecked) {
        check.dataset.savedCheckedBySidebar = check.classList.contains('checked') ? '1' : '0';
        check.classList.remove('checked');
        check.classList.add('master-disabled');
      } else {
        check.classList.remove('master-disabled');
        const saved = check.dataset.savedCheckedBySidebar;
        if (saved === '0') {
          check.classList.remove('checked');
        } else {
          check.classList.add('checked');
        }
        delete check.dataset.savedCheckedBySidebar;
        // Re-apply any nested master state
        if (check.dataset.masterFor) applyMasterState(check, check.classList.contains('checked'));
      }
    });
  }
  updateCounts();
}

function selectAll(sec, state) {
  // Toggle the sidebar master bar first
  const masterBar = document.querySelector(`.sidebar-master-check[data-section="${sec}"]`);
  if (masterBar) {
    masterBar.classList.toggle('checked', state);
    if (!state) {
      // Disabling sidebar master — dim all cards and uncheck all patches
      const section = masterBar.closest('.settings-section');
      if (section) {
        section.querySelectorAll('.settings-card').forEach(card => card.classList.add('master-disabled'));
        section.querySelectorAll('.patch-check').forEach(check => {
          check.dataset.savedCheckedBySidebar = check.classList.contains('checked') ? '1' : '0';
          check.classList.remove('checked');
          check.classList.add('master-disabled');
        });
      }
    } else {
      // Re-enabling sidebar master — restore all cards and patches
      const section = masterBar.closest('.settings-section');
      if (section) {
        section.querySelectorAll('.settings-card').forEach(card => card.classList.remove('master-disabled'));
        section.querySelectorAll('.patch-check').forEach(check => {
          check.classList.remove('master-disabled');
          delete check.dataset.savedCheckedBySidebar;
          check.classList.toggle('checked', state);
          if (check.dataset.masterFor) applyMasterState(check, state);
        });
      }
    }
  } else {
    document.querySelectorAll(`.patch-check[data-section="${sec}"]`).forEach(e => {
      if (state === false && e.classList.contains('master-disabled')) return;
      e.classList.toggle('checked', state);
      if (e.dataset.masterFor) applyMasterState(e, state);
    });
  }
  updateCounts();
}

document.querySelectorAll('.settings-nav-item').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.settings-nav-item').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    const sec = btn.dataset.section;
    document.querySelectorAll('.settings-section, .homepage-section').forEach(s => s.classList.remove('active'));
    const t = document.querySelector(`.settings-section[data-section="${sec}"], .homepage-section[data-section="${sec}"]`);
    if (t) t.classList.add('active');
  });
});

function looksLikeGUST(t) {
  if (typeof t !== 'string' || t.length < 50000) return false;
  if (!t.toLowerCase().includes('<!doctype html')) return false;
  // Must contain GUST-specific identifiers (present in the real source)
  return t.includes('GUST Browser') || t.includes('gust:') || t.includes('wisp.mercurywork');
}
async function fetchWithTimeout(url, ms, opts={}) {
  const c = new AbortController();
  const id = setTimeout(() => c.abort(), ms);
  try { const r = await fetch(url, {cache:'no-store', signal:c.signal, ...opts}); clearTimeout(id); return r; }
  catch(e) { clearTimeout(id); throw e; }
}
async function attemptFetch(url, label, opts={}) {
  document.getElementById('loadingSub').textContent = label;
  const res = await fetchWithTimeout(url, 15000, opts);
  if (!res.ok) throw new Error('HTTP ' + res.status);
  const text = await res.text();
  if (!looksLikeGUST(text)) throw new Error('Response (' + text.length + 'B) not valid GUST source');
  return text;
}
let _firstLoad = true;
async function fetchSource() {
  const ov = document.getElementById('loadingOverlay');
  ov.style.display = 'flex';
  document.getElementById('loadingSub').textContent = 'Connecting...';
  document.querySelectorAll('.error-box').forEach(e => e.remove());
  document.getElementById('downloadBtn').disabled = true;
  sourceLoaded = false;
  resetCheckboxesToDefault();

  // Attempt order: raw.githubusercontent (most reliable, direct HTML),
  // then CORS proxies that return raw content not the GitHub HTML page
  const attempts = [
    {label:'Fetching from GitHub Raw...',       url: RAW_URL,  opts: {headers:{'Accept':'text/html,application/xhtml+xml'}}},
    {label:'Fetching via jsDelivr CDN...',       url: 'https://cdn.jsdelivr.net/gh/nautilus-os/GUST@main/index.html', opts:{}},
    {label:'Fetching via codetabs proxy...',     url: 'https://api.codetabs.com/v1/proxy/?quest=' + RAW_URL, opts:{}},
    {label:'Fetching via allorigins...',         url: 'https://api.allorigins.win/raw?url=' + encodeURIComponent(RAW_URL), opts:{}},
  ];
  for (const a of attempts) {
    try {
      const text = await attemptFetch(a.url, a.label, a.opts);
      sourceHTML = text; sourceLoaded = true;
      ov.style.display = 'none';
      playBrandAnimation();
      setStatus('ok', 'Source loaded -- ' + (text.length/1024).toFixed(0) + ' KB');
      document.getElementById('downloadBtn').disabled = false;
      updateCounts();
      updatePresetButtons();
      if (_firstLoad) { _firstLoad = false; setTimeout(() => startPatcherTutorial(), 600); }
      return;
    } catch(err) { console.warn('[GUST Patcher] ' + a.label + ' failed:', err.message); }
  }
  ov.style.display = 'none';
  playBrandAnimation();
  setStatus('err', 'All fetch attempts failed -- open DevTools (F12) for details.');
  const active = document.querySelector('.settings-section.active');
  if (active) {
    const box = document.createElement('div');
    box.className = 'error-box';
    box.id = 'fetchErrorBox';
    box.innerHTML = `
      <i class="fas fa-triangle-exclamation"></i>
      <h3>Could not load GUST source</h3>
      <p>All fetch attempts failed (likely a network/CORS restriction).<br>
      Open DevTools (F12) → Console for details, then hit <strong style="color:var(--tx2)">Refresh Source</strong>.<br><br>
      <strong style="color:var(--tx2)">Or paste the GUST source manually below:</strong></p>
      <textarea id="manualSourceInput" placeholder="Paste the full GUST HTML here (download from github.com/nautilus-os/GUST)…"
        style="width:100%;height:120px;background:var(--bg3);border:1px solid var(--bd);border-radius:8px;padding:10px;
               color:var(--tx2);font-family:var(--mono);font-size:12px;resize:vertical;outline:none;margin-top:4px;"></textarea>
      <button id="manualSourceBtn" class="btn-primary" style="margin-top:2px;">
        <i class="fas fa-paste"></i> Use Pasted Source
      </button>`;
    active.prepend(box);

    document.getElementById('manualSourceBtn').addEventListener('click', () => {
      const val = document.getElementById('manualSourceInput').value.trim();
      if (!looksLikeGUST(val)) {
        setStatus('err', 'Pasted content does not look like valid GUST source — check you copied the full file.');
        return;
      }
      sourceHTML = val; sourceLoaded = true;
      box.remove();
      playBrandAnimation();
      setStatus('ok', 'Source loaded from paste — ' + (val.length/1024).toFixed(0) + ' KB');
      document.getElementById('downloadBtn').disabled = false;
      updateCounts();
    });
  }
  updateCounts();
}
function setStatus(type, text) {
  document.getElementById('statusText').textContent = text;
  const i = document.getElementById('statusIcon');
  i.className = type==='ok'?'fas fa-circle-check':type==='err'?'fas fa-circle-xmark':'fas fa-circle-info';
  i.style.color = type==='ok'?'var(--ok)':type==='err'?'var(--err)':'var(--ac)';
}

document.getElementById('downloadBtn').addEventListener('click', () => { if (sourceLoaded) buildAndDownload(); });
document.getElementById('reloadSourceBtn').addEventListener('click', fetchSource);

// Paste Source button — opens a modal for manually pasting GUST HTML
document.getElementById('pasteSourceBtn').addEventListener('click', () => {
  // Remove existing modal if any
  const existing = document.getElementById('pasteModal');
  if (existing) { existing.remove(); return; }
  const modal = document.createElement('div');
  modal.id = 'pasteModal';
  modal.style.cssText = 'position:fixed;inset:0;z-index:9998;display:flex;align-items:center;justify-content:center;background:rgba(0,0,0,0.6);backdrop-filter:blur(6px);';
  modal.innerHTML = `
    <div style="background:var(--bg2);border:1px solid var(--bd);border-radius:16px;padding:24px;width:520px;max-width:94vw;display:flex;flex-direction:column;gap:14px;box-shadow:0 16px 48px rgba(0,0,0,.7);">
      <div style="display:flex;align-items:center;justify-content:space-between;">
        <span style="font-size:15px;font-weight:700;color:var(--tx)"><i class="fas fa-paste" style="color:var(--ac);margin-right:8px;"></i>Paste GUST Source</span>
      </div>
      <p style="font-size:12px;color:var(--tx3);line-height:1.6;">
        Download <code style="background:var(--bg3);padding:1px 5px;border-radius:4px;">index.html</code> from
        <a href="https://github.com/nautilus-os/GUST" target="_blank" style="color:var(--ac)">github.com/nautilus-os/GUST</a>
        then paste the full file contents below.
      </p>
      <textarea id="pasteModalInput" placeholder="Paste the full GUST HTML here…"
        style="width:100%;height:160px;background:var(--bg3);border:1px solid var(--bd);border-radius:8px;
               padding:10px;color:var(--tx2);font-family:var(--mono);font-size:12px;resize:vertical;outline:none;"></textarea>
      <div style="display:flex;gap:8px;justify-content:flex-end;align-items:center;">
        <span id="pasteModalStatus" style="font-size:12px;color:var(--err);flex:1;"></span>
        <button id="pasteModalCancel" class="btn-secondary">Cancel</button>
        <button id="pasteModalLoad" class="btn-primary"><i class="fas fa-check"></i> Load Source</button>
      </div>
    </div>`;
  document.body.appendChild(modal);
  document.getElementById('pasteModalCancel').onclick = () => modal.remove();
  document.getElementById('pasteModalLoad').onclick = () => {
    const val = document.getElementById('pasteModalInput').value.trim();
    if (!looksLikeGUST(val)) {
      document.getElementById('pasteModalStatus').textContent = 'This does not look like valid GUST source — make sure you copied the complete index.html file.';
      return;
    }
    sourceHTML = val; sourceLoaded = true;
    modal.remove();
    // Remove any error box that was shown
    const errBox = document.getElementById('fetchErrorBox');
    if (errBox) errBox.remove();
    playBrandAnimation();
    setStatus('ok', 'Source loaded from paste — ' + (val.length/1024).toFixed(0) + ' KB');
    document.getElementById('downloadBtn').disabled = false;
    updateCounts();
  };
});

function getPatch(id) {
  const el = document.querySelector(`[data-patch="${id}"]`);
  return el ? el.classList.contains('checked') : true;
}

// STRATEGY: Never cut HTML/CSS/JS out of GUST source - that breaks it.
// Inject a small script before </head> that pre-seeds localStorage,
// hides elements with CSS, and stubs JS functions after load.
// The payload is base64-encoded so no special chars can break the HTML.

function buildPatchScript(removedPatches) {
  var rm = new Set(removedPatches);
  var lsLines = [];
  var cssRules = [];
  var jsLines = [];

  // ---- helpers ----
  // ls() writes both the bare key and the instance-prefixed key.
  // GUST wraps localStorage so all its reads go through `_INST_ID + ':' + key`.
  // The instance ID is stored in sessionStorage under '__gust_inst__'.
  function ls(key, val) {
    lsLines.push('(function(){');
    lsLines.push('  var _k=' + JSON.stringify(key) + ';');
    lsLines.push('  var _v=' + JSON.stringify(val) + ';');
    lsLines.push('  try{localStorage.setItem(_k,_v);}catch(e){}'); // bare key
    lsLines.push('  try{');
    lsLines.push('    var _id=sessionStorage.getItem("__gust_inst__")||window._sessionInstId;');
    lsLines.push('    if(_id){localStorage.setItem(_id+":"+_k,_v);}');
    lsLines.push('  }catch(e){}');
    lsLines.push('})();');
  }
  function css(sel) { cssRules.push(sel + ' { display:none !important; }'); }
  function js(line) { jsLines.push(line); }
  function stubFns(arr) {
    js('[' + arr.map(function(n){ return JSON.stringify(n); }).join(',') + '].forEach(function(fn){');
    js('  if(typeof window[fn]==="function") window[fn]=function(){};');
    js('});');
  }
  // badge(sel): hides all matched elements and inserts ONE "removed by patcher" pill
  // per unique .settings-switch-row/.settings-toggle-row ancestor found.
  // Selectors each in their own row each get their own badge.
  // Selectors sharing a row get a single shared badge.
  // Elements with no row ancestor: badge inserted after the element only if no row was found at all.
  function badge(sel) {
    css(sel);
    js('(function(){');
    js('  var _sels=' + JSON.stringify(sel.split(',').map(function(s){return s.trim();})) + ';');
    js('  function _mkBadge(){');
    js('    var b=document.createElement("div");');
    js('    b.style.cssText="display:inline-flex;align-items:center;gap:5px;padding:3px 9px;background:rgba(255,180,80,0.10);border:1px solid rgba(255,180,80,0.28);border-radius:6px;font-size:11px;font-family:var(--mono,monospace);color:rgba(255,180,80,0.85);white-space:nowrap;flex-shrink:0;margin-left:auto;";');
    js('    b.innerHTML=\'<i class="fas fa-lock" style="font-size:9px;"></i> removed by patcher\';');
    js('    return b;');
    js('  }');
    js('  function _inject(){');
    js('    var usedRows=[];');
    js('    var fallbackEl=null;');
    js('    for(var i=0;i<_sels.length;i++){');
    js('      var el=document.querySelector(_sels[i]);');
    js('      if(!el) continue;');
    js('      var row=el.closest(".settings-switch-row,.settings-toggle-row");');
    js('      if(row){');
    js('        if(usedRows.indexOf(row)===-1){');
    js('          usedRows.push(row);');
    js('          if(!row._gp_badged){row._gp_badged=true;row.appendChild(_mkBadge());}');
    js('        }');
    js('      } else if(!fallbackEl){');
    js('        fallbackEl=el;');
    js('      }');
    js('    }');
    js('    if(usedRows.length===0&&fallbackEl&&!fallbackEl._gp_badged){');
    js('      fallbackEl._gp_badged=true;');
    js('      fallbackEl.parentNode.insertBefore(_mkBadge(),fallbackEl.nextSibling);');
    js('    }');
    js('  }');
    js('  if(document.readyState==="loading"){document.addEventListener("DOMContentLoaded",_inject);}else{_inject();}');
    js('})();');
  }

  // ---- Sidebar nav hide rules (hides the nav item in GUST Browser Settings) ----
  if (rm.has('sidebar-nav-connection'))    css('.settings-nav-item[data-section=\"connection\"]');
  if (rm.has('sidebar-nav-aiassistant'))   css('.settings-nav-item[data-section=\"aiassistant\"]');
  if (rm.has('sidebar-nav-fallback'))      css('.settings-nav-item[data-section=\"fallback\"]');
  if (rm.has('sidebar-nav-search'))        css('.settings-nav-item[data-section=\"search\"]');
  if (rm.has('sidebar-nav-privacy'))       css('.settings-nav-item[data-section=\"privacy\"]');
  if (rm.has('sidebar-nav-cache'))         css('.settings-nav-item[data-section=\"cache\"]');
  if (rm.has('sidebar-nav-filesandmedia')) css('.settings-nav-item[data-section=\"filesandmedia\"]');
  if (rm.has('sidebar-nav-appearance'))    css('.settings-nav-item[data-section=\"appearance\"]');
  if (rm.has('sidebar-nav-homescreen'))    css('.settings-nav-item[data-section=\"homescreen\"]');
  if (rm.has('sidebar-nav-shortcuts'))     css('.settings-nav-item[data-section=\"shortcuts\"]');
  if (rm.has('sidebar-nav-language'))      css('.settings-nav-item[data-section=\"language\"]');
  if (rm.has('sidebar-nav-tutorial'))      css('.settings-nav-item[data-section=\"tutorial\"]');

  // ---- localStorage pre-seeds (keys verified against GUST source) ----
  if (rm.has('search-favicon'))  { ls('gust:favicon-proxy:v1','0'); }
  if (rm.has('webrtc-block'))    { ls('gust:webrtc:block:v1','0'); }
  if (rm.has('media-headers'))   { ls('gust:media:headers:v1','0'); }
  if (rm.has('adblock-toggle'))  { ls('gust:block:v1','false'); }
