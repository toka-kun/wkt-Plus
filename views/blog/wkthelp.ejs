<script>
    $(document).ready(function() {
      $('.faq-btn').click(function() {
        const content = $(this).next('.faq-content');
        const icon = $(this).find('.faq-icon');
        content.toggleClass('hidden');
        icon.toggleClass('rotate-180');
      });
    });
    const searchInput = document.getElementById('search');
    const toolList = document.getElementById('app-list');
    const tools = document.querySelectorAll('.faq-item');

    searchInput.addEventListener('input', function() {
        const searchText = searchInput.value.toLowerCase();
        tools.forEach(tool => {
            const title = tool.querySelector('.faq-title').textContent.toLowerCase();
            const description = tool.querySelector('.faq-content').textContent.toLowerCase();
            if (title.includes(searchText) || description.includes(searchText)) {
                tool.style.display = '';
            } else {
                tool.style.display = 'none';
            }
        });
    });
</script>

