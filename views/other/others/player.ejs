<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Player</title>

<style>
    :root {
      --main-color: #ff0000;
      --loop-color: #065fd4;
      --bg-color: #f9f9f9;
      --card-color: #ffffff;
      --text-color: #333;
      --shadow-color: rgba(0,0,0,0.08);
      --border-radius: 12px;
      --link-color: #065fd4;
    }

    :root.dark {
      --bg-color: #181818;
      --card-color: #202020;
      --text-color: #eaeaea;
      --shadow-color: rgba(0,0,0,0.4);
      --link-color: #3ea6ff;
    }

    @media (prefers-color-scheme: light) {
      :root.auto {
        --bg-color: #f9f9f9;
        --card-color: #ffffff;
        --text-color: #333;
        --shadow-color: rgba(0,0,0,0.08);
        --link-color: #065fd4;
      }
    }

    @media (prefers-color-scheme: dark) {
      :root.auto {
        --bg-color: #181818;
        --card-color: #202020;
        --text-color: #eaeaea;
        --shadow-color: rgba(0,0,0,0.4);
        --link-color: #3ea6ff;
      }
    }

    body {
      background-color: var(--bg-color);
      font-family: 'Segoe UI', sans-serif;
      color: var(--text-color);
      padding: 0.5rem;
      margin: 0;
    }

    h1 {
      text-align: center;
      font-size: 1.6rem;
      margin: 0.5rem 0 1rem 0;
    }

    .theme-switcher {
      position: fixed;
      top: 10px;
      right: 10px;
      padding: 0.3rem;
    }

    .layout {
      display: flex;
      flex-direction: column;
      gap: 1rem;
      max-width: 1200px;
      margin: auto;
    }

    @media (min-width: 900px) {
      .layout-main {
        flex-direction: row;
      }
      .left, .right {
        flex: 1;
      }
      .left { max-width: 65%; }
      .right { max-width: 35%; }
    }

    .card {
      background: var(--card-color);
      border-radius: var(--border-radius);
      box-shadow: 0 4px 12px var(--shadow-color);
      padding: 1rem;
    }

    label {
      font-weight: bold;
      display: block;
      margin-bottom: 0.4rem;
    }

    /* Input Wrapper for Clear Button Position */
    .input-wrapper {
      position: relative;
      margin-bottom: 1rem;
    }

    input[type="text"], select {
      width: 100%;
      padding: 0.75rem;
      font-size: 1rem;
      border: 1px solid #ccc;
      border-radius: var(--border-radius);
      box-sizing: border-box;
      background: var(--card-color);
      color: var(--text-color);
    }
    
    select {
      margin-bottom: 1rem;
    }
    
    /* Add padding to right so text doesn't hit the X button */
    #videoUrlInput, #startTimeInput, #endTimeInput {
      padding-right: 2.5rem;
    }

    /* Clear Button Style */
    .clear-btn {
      position: absolute;
      right: 5px;
      top: 50%;
      transform: translateY(-50%);
      width: auto;
      background: transparent;
      color: #999;
      border: none;
      font-size: 1.2rem;
      cursor: pointer;
      padding: 0 0.5rem;
      display: none; /* Initially hidden */
      line-height: 1;
      height: 80%;
      border-radius: 4px;
    }
    
    .clear-btn:hover {
      color: var(--text-color);
      background-color: rgba(128, 128, 128, 0.1);
      opacity: 1;
    }

    /* Main Buttons */
    .action-btn {
      background-color: var(--main-color);
      color: white;
      border: none;
      padding: 0.75rem 1rem;
      font-size: 1rem;
      border-radius: var(--border-radius);
      cursor: pointer;
      width: 100%;
      transition: opacity 0.2s, transform 0.1s;
    }
    
    .action-btn:hover {
      opacity: 0.9;
    }
    .action-btn:active {
      transform: scale(0.98);
    }

    .btn-loop {
      background-color: var(--loop-color);
      margin-top: 0.8rem;
    }

    #videoContainer {
      width: 100%;
      aspect-ratio: 16 / 9;
      background-color: #000;
      border-radius: var(--border-radius);
      overflow: hidden;
      position: relative;
    }

    iframe, img.thumbnail-display {
      width: 100%;
      height: 100%;
      border: none;
      object-fit: contain;
    }

    .time-inputs {
      display: flex;
      gap: 1rem;
      margin-bottom: 0.5rem;
    }
    .time-inputs > div {
      flex: 1;
    }

    /* --- コメント欄 --- */
    .comments-wrapper summary {
      cursor: pointer;
      font-weight: bold;
      font-size: 1.1rem;
      padding: 0.5rem;
      outline: none;
      list-style: none;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .comments-wrapper summary::-webkit-details-marker {
      display: none;
    }
    .comments-wrapper summary::after {
      content: '+'; 
      font-size: 1.5rem;
      font-weight: normal;
    }
    .comments-wrapper details[open] summary::after {
      content: '-';
    }
    
    .comment-list {
      margin-top: 1rem;
      border-top: 1px solid #ddd;
      padding-top: 1rem;
    }
    
    .comment-item {
      display: flex;
      gap: 1rem;
      margin-bottom: 1.5rem;
      border-bottom: 1px solid rgba(128, 128, 128, 0.1);
      padding-bottom: 1rem;
    }
    
    .comment-avatar img {
      width: 40px;
      height: 40px;
      border-radius: 50%;
      object-fit: cover;
    }
    
    .comment-content {
      flex: 1;
      overflow-wrap: anywhere;
    }
    
    .comment-header {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 0.5rem;
      margin-bottom: 0.2rem;
      font-size: 0.9rem;
    }
    
    .author-name {
      font-weight: bold;
      text-decoration: none;
      color: var(--text-color);
    }
    
    .badge {
      font-size: 0.7rem;
      padding: 2px 6px;
      border-radius: 4px;
      color: #fff;
      font-weight: bold;
    }
    
    .published-date {
      color: #888;
      font-size: 0.85rem;
    }

    .edited-mark {
      color: #888;
      font-style: italic;
      font-size: 0.8rem;
    }

    .comment-text {
      font-size: 0.95rem;
      line-height: 1.4;
      margin: 0.3rem 0;
    }
    
    .comment-text a {
      color: var(--link-color);
      text-decoration: none;
    }
    .comment-text a:hover {
      text-decoration: underline;
    }

    .timestamp-link {
      color: var(--link-color);
      text-decoration: none;
      cursor: pointer;
    }
    .timestamp-link:hover {
      text-decoration: underline;
    }

    .comment-footer {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
      font-size: 0.85rem;
      color: #888;
    }

    .footer-actions {
      display: flex;
      align-items: center;
      gap: 1rem;
    }

    .creator-heart {
      display: flex;
      align-items: center;
      gap: 6px;
    }
    .creator-heart img {
      width: 20px;
      height: 20px;
      border-radius: 50%;
    }
    .heart-icon {
      color: #ff0000;
      font-size: 0.9rem;
      position: relative;
    }
    .heart-badge-wrapper {
        position: relative;
        display: inline-block;
    }
    .heart-badge-icon {
        position: absolute;
        bottom: -2px;
        right: -4px;
        font-size: 10px;
    }

    .badge-pinned, .badge-owner {
      background-color: #606060 !important;
      color: #ffffff !important;
      opacity: 1 !important;
    }

    :root.dark .badge-pinned,
    :root.dark .badge-owner,
    @media (prefers-color-scheme: dark) {
      :root.auto .badge-pinned,
      :root.auto .badge-owner {
        background-color: #888888 !important;
        color: #181818 !important;
      }
    }
  </style>
</head>

<body>

<div class="theme-switcher">
  <select id="themeSelect" onchange="changeTheme(this.value)">
    <option value="auto">自動</option>
    <option value="light">ライト</option>
    <option value="dark">ダーク</option>
  </select>
</div>

<h1>YouTube 埋め込み再生ツール by Toka_Kun_</h1>

<div class="layout layout-main">

  <div class="left">
    <div id="videoContainer"></div>
  </div>

  <div class="right">
    <div class="card">

      <label>使用する再生方法：</label>
      <select id="paramSource">
        <optgroup label="埋め込み再生">
            <option value="Nocookie">Nocookie</option>
            <option value="Education - wakame">Education - wakame</option>
            <option value="Education - siawaseok">Education - siawaseok</option>
            <option value="Education - Toka_Kun_-1">Education - Toka_Kun_-1</option>
            <option value="Education - Toka_Kun_-2">Education - Toka_Kun_-2</option>
            <option value="Education - Toka_Kun_-3">Education - Toka_Kun_-3</option>
            <option value="Education - Toka_Kun_-4">Education - Toka_Kun_-4</option>
            <option value="Education - woolisbest4520-1">Education - woolisbest4520-1</option>
            <option value="Education - woolisbest4520-2">Education - woolisbest4520-2</option>
            <option value="Education - woolisbest4520-3">Education - woolisbest4520-3</option>
            <option value="Education - woolisbest4520-4">Education - woolisbest4520-4</option>
            <option value="Education - woolisbest4520-5">Education - woolisbest4520-5</option>
        </optgroup>
        
        <optgroup label="サムネイル">
            <option value="Thumbnail-maxresdefault">maxresdefault</option>
            <option value="Thumbnail-sddefault">sddefault</option>
            <option value="Thumbnail-hqdefault">hqdefault</option>
            <option value="Thumbnail-mqdefault">mqdefault</option>
            <option value="Thumbnail-default">default</option>
      </select>

      <label>YouTubeのURLまたは動画IDを入力：</label>
      <div class="input-wrapper">
        <input type="text" id="videoUrlInput"
          placeholder="例: https://youtu.be/HRlW6yZo6Kc?list=PLxxx... または HRlW6yZo6Kc">
        <button id="btnClearInput" class="clear-btn" aria-label="クリア">×</button>
      </div>

      <div class="time-inputs">
        <div>
          <label for="startTimeInput">開始位置</label>
          <div class="input-wrapper">
            <input type="text" id="startTimeInput" placeholder="例: 1:30, 90">
            <button id="btnClearStart" class="clear-btn" aria-label="クリア">×</button>
          </div>
        </div>
        <div>
          <label for="endTimeInput">終了位置</label>
          <div class="input-wrapper">
            <input type="text" id="endTimeInput" placeholder="例: 2:00, 120">
            <button id="btnClearEnd" class="clear-btn" aria-label="クリア">×</button>
          </div>
        </div>
      </div>

      <button id="btnPlay" class="action-btn" onclick="loadVideo(false)">▶️ 再生</button>
      <button id="btnLoop" class="action-btn btn-loop" onclick="loadVideo(true)">🔁 ループ再生</button>

    </div>
  </div>

</div>

<div class="layout" style="margin-top: 1rem;">
  <div class="card comments-wrapper">
    <details open>
      <summary>コメント <span id="commentCountBadge"></span></summary>
      <div id="commentsContainer" class="comment-list">
        <p style="text-align:center; color:#888;">動画を再生するとここにコメントが表示されます。</p>
      </div>
    </details>
  </div>
</div>

<script>
  // --- YouTube IFrame Player API ---
  var tag = document.createElement('script');
  tag.src = "https://www.youtube.com/iframe_api";
  var firstScriptTag = document.getElementsByTagName('script')[0];
  firstScriptTag.parentNode.insertBefore(tag, firstScriptTag);

  var player = null;
  var currentLoadedVideoId = null;

  function applyTheme(mode) {
    document.documentElement.classList.remove("light", "dark", "auto");
    document.documentElement.classList.add(mode);
  }

  function changeTheme(mode) {
    applyTheme(mode);
    localStorage.setItem("themeMode", mode);
  }

  // --- 初期化 ---
  (function() {
    const savedTheme = localStorage.getItem("themeMode") || "auto";
    applyTheme(savedTheme);
    document.getElementById("themeSelect").value = savedTheme;

    const savedSource = localStorage.getItem("preferredSource");
    if (savedSource) {
      const sourceSelect = document.getElementById("paramSource");
      const optionExists = Array.from(sourceSelect.options).some(opt => opt.value === savedSource);
      if (optionExists) {
        sourceSelect.value = savedSource;
      }
    }
  })();

  // --- イベントリスナー ---
  document.getElementById("paramSource").addEventListener("change", function() {
    localStorage.setItem("preferredSource", this.value);
  });

  // --- 入力欄のクリア機能とEnterキー処理 (URL, 開始, 終了) ---
  const inputGroups = [
    { inputId: "videoUrlInput", btnId: "btnClearInput" },
    { inputId: "startTimeInput", btnId: "btnClearStart" },
    { inputId: "endTimeInput", btnId: "btnClearEnd" }
  ];

  function setupInputControl(group) {
    const input = document.getElementById(group.inputId);
    const btn = document.getElementById(group.btnId);
    if (!input || !btn) return;

    // ボタンの表示/非表示を切り替える関数
    const toggleBtn = () => {
      btn.style.display = input.value.length > 0 ? "block" : "none";
    };

    // 入力時にボタン表示判定
    input.addEventListener("input", toggleBtn);

    // クリアボタンクリック時
    btn.addEventListener("click", function() {
      input.value = "";
      input.focus();
      toggleBtn();
    });

    // Enterキーで再生
    input.addEventListener("keydown", function(event) {
      if (event.key === "Enter") {
        event.preventDefault();
        loadVideo(false);
      }
    });

    // 初期状態チェックのために関数をプロパティとして保存しておく
    input.checkClearButton = toggleBtn;
  }

  // 全てのグループに設定を適用
  inputGroups.forEach(setupInputControl);
  
  // ページ読み込み時にURL欄にフォーカスする
  document.getElementById("videoUrlInput").focus();

  // URL入力時に start/end パラメータを自動検知して入力欄に反映する処理
  document.getElementById("videoUrlInput").addEventListener("input", function() {
    const val = this.value;
    const startInput = document.getElementById("startTimeInput");
    const endInput = document.getElementById("endTimeInput");

    // t= または start= を探す (例: ?t=90, &start=120, &amp;start=120)
    const startMatch = val.match(/[?&](?:amp;)?(?:t|start)=([^&]+)/);
    if (startMatch) {
      // パラメータがある場合：値を抽出してセット
      let t = startMatch[1];
      if (t.endsWith('s') && !t.includes('m') && !t.includes('h')) {
         t = t.slice(0, -1);
      }
      startInput.value = t;
    } else {
      // パラメータがない場合：入力欄をクリアする
      startInput.value = "";
    }
    // ×ボタンの表示状態を更新（値が入れば表示、消えれば非表示）
    if (startInput.checkClearButton) startInput.checkClearButton();

    // end= を探す (例: ?end=200, &amp;end=200)
    // --- 終了位置 (end=) の処理 ---
    const endMatch = val.match(/[?&](?:amp;)?end=([^&]+)/);
    if (endMatch) {
      // パラメータがある場合
      let t = endMatch[1];
      if (t.endsWith('s') && !t.includes('m') && !t.includes('h')) {
         t = t.slice(0, -1);
      }
      endInput.value = t;
    } else {
      // パラメータがない場合
      endInput.value = "";
    }
    // ×ボタンの表示状態を更新
    if (endInput.checkClearButton) endInput.checkClearButton();
  });

  // 全てのボタン状態を一括チェックする関数（ページ読み込み時や復元時用）
  function checkAllInputs() {
    inputGroups.forEach(group => {
      const input = document.getElementById(group.inputId);
      if (input && input.checkClearButton) {
        input.checkClearButton();
      }
    });
  }
  
  // タブ複製や戻る操作で値が復元されたときのために複数のイベントでチェック
  window.addEventListener('pageshow', checkAllInputs);
  document.addEventListener('DOMContentLoaded', checkAllInputs);
  // ブラウザの自動入力遅延対策
  setTimeout(checkAllInputs, 100);


  const URLS = {
    "Nocookie": null,
    "Education - wakame": "/wkt/yt/edurl_wakame",
    "Education - siawaseok": "/wkt/yt/edurl_sia",
    "Education - Toka_Kun_-1": "/wkt/yt/edurl_toka1",
    "Education - Toka_Kun_-2": "/wkt/yt/edurl_toka2",
    "Education - Toka_Kun_-3": "/wkt/yt/edurl_toka3",
    "Education - Toka_Kun_-4": "/wkt/yt/edurl_toka4",
    "Education - woolisbest4520-1": "/wkt/yt/edurl_wool1",
    "Education - woolisbest4520-2": "/wkt/yt/edurl_wool2",
    "Education - woolisbest4520-3": "/wkt/yt/edurl_wool3",
    "Education - woolisbest4520-4": "/wkt/yt/edurl_wool4",
    "Education - woolisbest4520-5": "/wkt/yt/edurl_wool5"
  };

  function extractVideoId(input) {
    if (!input) return null;
    const patterns = [
      // 1. パラメータ型: ドメイン不問
      //    /watch?v=ID, /watch_main?v=ID, /w?v=ID, /embed?v=ID, /edu?v=ID, /ume?v=ID, /nocookie?v=ID, /thumbnail?v=ID
      //    これらを　/(?:\/watch|\/watch_main|\/w|\/embed|\/edu|\/ume|\/nocookie|\/thumbnail)\?(?:.*&)?v=([\w-]{11})/, 
      //    みたいに分けてたけどドメインやパスに関係なく、?v=ID または &v=ID が含まれていれば反応するように統一。
      //    他のパラメータが前後にあっても対応 (?foo=bar&v=ID)
      /[?&]v=([\w-]{11})/,

      // 2. パス型: ドメイン不問
      //    youtu.be/ID
      //    /embed/ID, /shorts/ID, /live/ID, /vi/ID, /videos/ID, /watch/ID, /w/ID, /s/ID, /v/ID, /video/ID, /stream/ID, /streams/ID, /m3u8/ID
      //    /nocookie/ID, /edu/ID, /education/ID, /umekomi/ID, /stream_360p_url/ID, /stream_high/ID
      /(?:youtu\.be|embed|shorts|live|vi|videos|watch|w|s|v|video|stream|streams|m3u8|nocookie|edu|education|umekomi|stream_360p_url|stream_high)\/([\w-]{11})/
    ];
    for (const p of patterns) {
      const m = input.match(p);
      if (m) return m[1];
    }
    if (/^[\w-]{11}$/.test(input)) return input;
    return null;
  }

  function extractListId(input) {
    if (!input) return null;
    const m = input.match(/[?&](?:list|playlist)=([a-zA-Z0-9_-]+)/);
    return m ? m[1] : null;
  }

  function convertToSeconds(input) {
    if (!input) return null;
    const str = input.replace(/[０-９]/g, s => String.fromCharCode(s.charCodeAt(0) - 0xFEE0)).replace(/：/g, ':').trim();
    if (!str) return null;
    if (str.includes(':')) {
      const parts = str.split(':').map(Number);
      if (parts.some(isNaN)) return null;
      if (parts.length === 3) return parts[0] * 3600 + parts[1] * 60 + parts[2];
      if (parts.length === 2) return parts[0] * 60 + parts[1];
    }
    const val = parseInt(str, 10);
    return isNaN(val) ? null : val;
  }

  function updateUrlParam(url, key, value) {
    // 以下のパターン全てにマッチする正規表現を作成します
    // 1. ?start=0
    // 2. &start=0
    // 3. &amp;start=0 (HTMLエンティティが含まれる場合)
    // 4. ?amp;start=0
    
    // 正規表現の解説:
    // ([?&])       -> グループ1: '?' または '&' の開始文字をキャプチャ
    // (?:amp;)?    -> 'amp;' という文字列があってもなくてもマッチ（キャプチャはしない）
    // ${key}=      -> パラメータ名とイコール（例: start=）
    // [^&]* -> 次の '&' が来るまで、または文字列の終わりまでの値
    const regex = new RegExp(`([?&])(?:amp;)?${key}=[^&]*`, 'gi');

    // URL内にすでにそのキー（例: start）が存在するかチェック
    if (regex.test(url)) {
       // 存在する場合、その部分を新しい値に置換します
       // match: マッチした文字列全体, separator: 最初の?か&
       return url.replace(regex, (match, separator) => {
          // セパレータ(?か&)を維持しつつ、amp;を除去して値を更新
          return `${separator}${key}=${value}`;
       });
    }

    // 存在しない場合は、末尾に新規追加します
    const separator = url.includes('?') ? '&' : '?';
    return `${url}${separator}${key}=${value}`;
  }

  // --- XSS対策のための簡易サニタイザー ---
  function sanitizeHTML(html) {
    const div = document.createElement('div');
    div.innerHTML = html;
    // 危険なタグを削除
    const dangerousTags = ['script', 'iframe', 'object', 'embed', 'form', 'style', 'meta', 'link'];
    dangerousTags.forEach(tag => {
      const elements = div.querySelectorAll(tag);
      elements.forEach(el => el.remove());
    });
    // イベントハンドラ属性(onClick等)とjavascript:プロトコルを削除
    const allElements = div.querySelectorAll('*');
    allElements.forEach(el => {
      Array.from(el.attributes).forEach(attr => {
        if (attr.name.startsWith('on') || 
           (attr.value && attr.value.toLowerCase().includes('javascript:'))) {
          el.removeAttribute(attr.name);
        }
      });
    });
    return div.innerHTML;
  }

  function parseTimestamp(text) {
    const regex = /\b(?:(\d{1,2}):)?(\d{1,2}):(\d{2})\b/g;
    return text.replace(regex, (match, h, m, s) => {
      let seconds = 0;
      if (h) seconds += parseInt(h) * 3600;
      seconds += parseInt(m) * 60;
      seconds += parseInt(s);
      return `<a class="timestamp-link" onclick="seekVideo(${seconds}); return false;">${match}</a>`;
    });
  }

  function seekVideo(seconds) {
    if (player && typeof player.seekTo === 'function') {
        player.seekTo(seconds, true);
        return;
    }
    const frame = document.getElementById("videoFrame");
    if (!frame) return;
    
    let src = frame.src;
    if (!src || src.includes("/wkt/back") || src === "about:blank") return;
    const newSrc = updateUrlParam(src, 'start', seconds);
    if (src !== newSrc) frame.src = newSrc;
  }

  function onPlayerStateChange(event) {
    if (event.data === YT.PlayerState.PLAYING || event.data === YT.PlayerState.BUFFERING) {
        if (event.target && event.target.getVideoData) {
            const data = event.target.getVideoData();
            if (data && data.video_id) {
                // プレイヤー内で動画が変わった場合(自動遷移など)のみ更新
                if (currentLoadedVideoId && data.video_id !== currentLoadedVideoId) {
                    currentLoadedVideoId = data.video_id;
                    fetchComments(currentLoadedVideoId);
                }
            }
        }
    }
  }

  function initYouTubePlayer() {
    if (typeof YT === 'undefined' || typeof YT.Player === 'undefined') return; 
    try {
        player = new YT.Player('videoFrame', {
            events: {
                'onStateChange': onPlayerStateChange
            }
        });
    } catch (e) {
        console.error("YouTube Player APIの初期化に失敗しました", e);
    }
  }

  // APIリストを保存しておくための変数（無駄な通信を減らすため）
  let cachedApiUrls = null;

  const fallbackApiUrls = [
    "https://min-tube2-api.vercel.app",
    "https://min-tube-api-3.vercel.app",
    "https://min-tube-api4.vercel.app",
    "https://server-minp.vercel.app",
    "https://min-tube-api5.vercel.app"
  ];

  async function fetchComments(videoId) {
    const container = document.getElementById("commentsContainer");
    const countBadge = document.getElementById("commentCountBadge");
    
    container.innerHTML = '<p style="text-align:center;">読み込み中...</p>';
    countBadge.innerText = '';

    try {

    // 1. APIリストの取得（キャッシュがなければ取得する）
      if (!cachedApiUrls) {
        try {
          const listRes = await fetch("/wkt/yt/min-tube-api.json");
          if (!listRes.ok) throw new Error("APIリストのステータスエラー");
          
          // テキストとして取得し、カンマで区切って配列化する
          const textData = await listRes.text();
          cachedApiUrls = textData
            .split(',')
            .map(url => url.trim()) // 余分な空白や改行を削除
            .filter(url => url.length > 0); // 空文字を除外
            
        } catch (err) {
          // 取得エラー時はフォールバックのリストを代入する ▼▼▼
          console.warn("GitHubからのAPIリスト取得に失敗したため、予備のAPIリストを使用します。", err);
          cachedApiUrls = fallbackApiUrls;
        }
      }

      let data = null;
      let isSuccess = false;

      // 2. リスト内のURLを順番に試す
      for (const baseUrl of cachedApiUrls) {
        try {
          // 末尾にスラッシュがある場合を考慮してクリーンに結合
          const apiUrl = `${baseUrl.replace(/\/$/, '')}/api/comments/${videoId}`;
          const res = await fetch(apiUrl);
          
          if (res.ok) {
            data = await res.json();
            isSuccess = true;
            break; // 取得に成功したらループを抜ける
          }
        } catch (err) {
          // ネットワークエラーなどの場合はコンソールに警告を出して次へ
          console.warn(`${baseUrl} からの取得に失敗しました。次を試します...`, err);
        }
      }

      // 全てのAPIを試してもダメだった場合
      if (!isSuccess || !data) {
        throw new Error("すべてのAPIサーバーでコメント取得に失敗しました");
      }
      
      // --- ここから下は元の表示処理と同じ ---
      if (!data.comments || data.comments.length === 0) {
        container.innerHTML = '<p style="text-align:center;">コメントが見つかりませんでした。</p>';
        return;
      }

      countBadge.innerText = `(${data.commentCount || data.comments.length})`;
      
      let html = '';
      data.comments.forEach(c => {
        const iconUrl = (c.authorThumbnails && c.authorThumbnails.length > 0) ? c.authorThumbnails[0].url : '';
        
        let badges = '';
        if (c.isPinned) badges += `<span class="badge badge-pinned">固定済み</span>`;
        if (c.authorIsChannelOwner) badges += `<span class="badge badge-owner">所有者</span>`;

        let editedHtml = '';
        if (c.isEdited) editedHtml = `<span class="edited-mark">(編集済み)</span>`;

        let replyCountHtml = '';
        if (c.replies && c.replies.replyCount) {
           const count = Number(c.replies.replyCount);
           if (count > 0) {
             replyCountHtml = `<span style="margin-left: 0.5rem">💬 ${count}</span>`; // margin-leftの記述を少し修正しています
           }
        }

        let heartHtml = '';
        if (c.creatorHeart) {
          const ownerThumb = c.creatorHeart.creatorThumbnail || iconUrl; 
          heartHtml = `
            <div class="creator-heart">
              <div class="heart-badge-wrapper">
                <img src="${ownerThumb}" alt="Owner">
                <span class="heart-badge-icon">❤️</span>
              </div>
              <span>${c.creatorHeart.creatorName || '所有者'} がハートを付けました</span>
            </div>
          `;
        }

        let safeHtml = sanitizeHTML(c.contentHtml);
        safeHtml = safeHtml.replace(/<a /g, '<a target="_blank" rel="noopener noreferrer" ');
        const processedContent = parseTimestamp(safeHtml);

        html += `
          <div class="comment-item">
            <div class="comment-avatar">
              <a href="https://www.youtube.com${c.authorUrl}" target="_blank">
                <img src="${iconUrl}" alt="${c.author}">
              </a>
            </div>
            <div class="comment-content">
              <div class="comment-header">
                <a href="https://www.youtube.com${c.authorUrl}" target="_blank" class="author-name">${c.author}</a>
                ${badges}
                <span class="published-date">${c.publishedText}</span>
                ${editedHtml}
              </div>
              <div class="comment-text">
                ${processedContent}
              </div>
              <div class="comment-footer">
                <div class="footer-actions">
                  <span>👍 ${c.likeCount}</span>
                  ${replyCountHtml} 
                </div>
                ${heartHtml}
              </div>
            </div>
          </div>
        `;
      });
      container.innerHTML = html;
    } catch (e) {
      console.error(e);
      container.innerHTML = '<p style="text-align:center; color:red;">コメントの取得に失敗しました。</p>';
    }
  }

  function resetButtons() {
    document.getElementById("btnPlay").innerText = "▶️ 再生";
    document.getElementById("btnLoop").innerText = "🔁 ループ再生";
  }

  async function loadVideo(isLoop = false) {
    const btnPlay = document.getElementById("btnPlay");
    const btnLoop = document.getElementById("btnLoop");

    const input = document.getElementById("videoUrlInput").value.trim();
    if (!input) {
      alert("URLまたは動画IDを入力してください。");
      return;
    }

    resetButtons();
    if (isLoop) {
      btnLoop.innerText = "🔁 ループ再生中...";
    } else {
      btnPlay.innerText = "▶️ 再生中...";
    }

    if (player) {
      try { player.destroy(); } catch(e) {}
      player = null;
    }

    const container = document.getElementById("videoContainer");
    container.innerHTML = '';
    
    const source = document.getElementById("paramSource").value;
    const videoId = extractVideoId(input);
    const listId = extractListId(input);

    if (!videoId) {
      alert("正しいURLまたは動画IDを入力してください。");
      resetButtons();
      return;
    }

    // --- 修正: 同じ動画IDの場合はコメントを再取得しない ---
    if (currentLoadedVideoId !== videoId) {
        currentLoadedVideoId = videoId;
        fetchComments(videoId);
    }
    // ------------------------------------------------

    if (source.startsWith("Thumbnail-")) {
      if (isLoop) {
        alert("サムネイル（画像）はループ再生できません。");
        resetButtons();
        return;
      }
      
      const quality = source.replace("Thumbnail-", "");
      
      const img = document.createElement("img");
      img.className = "thumbnail-display";
      // /wkt/back/vi/動画ID/画質.jpg の形式で出力します
      img.src = `/wkt/back/vi/${videoId}/${quality}.jpg`;
      container.appendChild(img);
      
      resetButtons();
      return;
    }

    const newIframe = document.createElement("iframe");
    newIframe.id = "videoFrame";
    newIframe.allowFullscreen = true;
    newIframe.allow = "accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share";
    newIframe.referrerPolicy = "strict-origin-when-cross-origin";
    
    container.appendChild(newIframe);

    const startInput = document.getElementById("startTimeInput").value;
    const endInput = document.getElementById("endTimeInput").value;
    const startSeconds = convertToSeconds(startInput);
    const endSeconds = convertToSeconds(endInput);

    let finalUrl = "";

    try {
        if (source === "Nocookie") {
          finalUrl = `https://www.youtube-nocookie.com/embed/${videoId}?autoplay=1&amp;mute=0`;
        } else {
            const r = await fetch(URLS[source], { cache: "no-store" });
            if (!r.ok) throw new Error("取得失敗");

            let params = "";
            
            if (source === "Education - wakame") {
              params = await r.text();
            } else if (source === "Education - siawaseok") {
              params = await r.text();
            } else if (source === "Education - Toka_Kun_-1") {
              params = await r.text();
            } else if (source === "Education - Toka_Kun_-2") {
              params = await r.text();
            } else if (source === "Education - Toka_Kun_-3") {
              params = await r.text();
            } else if (source === "Education - Toka_Kun_-4") {
              params = await r.text();
            } else if (source === "Education - woolisbest4520-1") {
              params = await r.text();
            } else if (source === "Education - woolisbest4520-2") {
              params = await r.text();
            } else if (source === "Education - woolisbest4520-3") {
              params = await r.text();
            } else if (source === "Education - woolisbest4520-4") {
              params = await r.text();
            } else if (source === "Education - woolisbest4520-5") {
              params = await r.text();
            }
            
            finalUrl = `https://www.youtubeeducation.com/embed/${videoId}${params}`;
        }
    } catch (e) {
        console.error(e);
        alert("設定の取得に失敗しました。");
        resetButtons();
        return;
    }

    if (listId) {
      if (listId === videoId) {
        finalUrl = updateUrlParam(finalUrl, 'playlist', listId);
      } else {
        finalUrl = updateUrlParam(finalUrl, 'list', listId);
      }
    } else {
      finalUrl = updateUrlParam(finalUrl, 'playlist', videoId);
    }

    if (isLoop) {
      finalUrl = updateUrlParam(finalUrl, 'loop', '1');
    }

    if (startSeconds !== null) finalUrl = updateUrlParam(finalUrl, 'start', startSeconds);
    if (endSeconds !== null) finalUrl = updateUrlParam(finalUrl, 'end', endSeconds);

    finalUrl = updateUrlParam(finalUrl, 'enablejsapi', '1');
    finalUrl = updateUrlParam(finalUrl, 'origin', window.location.origin);

    newIframe.onload = function() {
        initYouTubePlayer();
    };
    
    newIframe.src = finalUrl;
  }
</script>

</body>
</html>
