<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= query %> - 検索</title>
    <link rel="stylesheet" href="/css/page.css">
    <script src="/js/tailwindcss.js"></script>
    <link rel="stylesheet" href="https://code.jquery.com/ui/1.12.1/themes/base/jquery-ui.css">
    <script src="https://code.jquery.com/jquery-3.5.1.js"></script>
    <script src="https://code.jquery.com/ui/1.12.1/jquery-ui.js"></script>
    <script src="/js/tube.js"></script>
<style>
.result-item {
  position: relative;
}
.searchbox {
  padding-right: 30px;
}
</style>
</head>
<body class="bg-gray-900 text-white">
    <header class="bg-gray-800 flex p-4 justify-between items-center">
        <input type="text" placeholder="Welcome" class="w-full p-2 rounded bg-gray-700 text-white">
        <nav class="space-x-4">
            <p class="text-gray-300 hover:text-white">わかめtube</p>
        </nav>
    </header>
    <header class="bg-gray-800 p-4 flex justify-between items-center fixed top-0 left-0 w-full z-10">
        <form action="/wkt/s" method="get" class="w-1/2 relative" id="searchForm">
            <input type="text" name="q" id="searchbox" placeholder="検索" value="<%= query %>" class="searchbox w-full p-2 pr-10 rounded bg-gray-700 text-white">
            <button type="button" id="clearBtn" class="absolute right-2 top-1/2 -translate-y-1/2 flex items-center justify-center h-6 w-6 rounded-full hover:bg-gray-400 text-white text-lg leading-none hidden">
             ×
            </button>
        </form>
        <nav class="space-x-4">
            <a href="/wkt" class="text-gray-300 hover:text-white">ホーム</a>
            <a href="/wkt/trend" class="text-gray-300 hover:text-white">トレンド</a>
            <a href="/wkt/cl/fav" class="text-gray-300 hover:text-white">お気に入り</a>
            <a href="/wkt/cl/history" class="text-gray-300 hover:text-white">再生履歴</a>
        </nav>
    </header>
    
    <div class="container mx-auto p-4">
        <% const videoCount = res.results.filter(v => v.type.endsWith("Video")).length; %>
        <h2 class="text-xl font-bold mb-4">検索結果: <%= query %> <span class="text-gray-400 text-base font-normal">(<%= videoCount %>件)</span></h2>
  
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
            <% res.results.forEach(video => { %>
              <% if (video.type.endsWith("Video")) { %>
                <div class="result-item bg-gray-800 p-4 rounded-lg shadow hover:bg-gray-700 transition duration-200">
                    <a href="/wkt/watch/<%= video.id %>" class="block relative group">
                        <img loading="lazy" src="/wkt/back/vi/<%= video.id %>/mqdefault.jpg" alt="<%= video.title.text %>" class="w-full h-auto rounded aspect-video object-cover">
                        <% if (video.duration?.text) { %>
                        <span class="absolute bottom-1 right-1 bg-black bg-opacity-80 text-white text-xs px-1.5 py-0.5 rounded font-medium"><%= video.duration.text %></span>
                        <% } %>
                        <div class="absolute inset-0 bg-black bg-opacity-0 group-hover:bg-opacity-10 transition rounded"></div>
                    </a>
                    <div class="mt-3 flex items-start space-x-3">
                        <a href="<%= (video.author?.id && video.author.id !== 'N/A') ? '/wkt/c/' + video.author.id : '/wkt/watch/' + video.id %>" class="flex-shrink-0">
                            <img src="/wkt/back/yt3<%- (new URL(video.author.thumbnails[0].url)).pathname %>" alt="<%= video.author.name %>" class="w-9 h-9 rounded-full object-cover bg-gray-600 border border-gray-700">
                        </a>
                        <div class="flex-1 min-w-0">
                            <a href="/wkt/watch/<%= video.id %>">
                                <p class="text-white font-bold text-sm leading-snug line-clamp-2 mb-1 hover:text-blue-400 transition"><%= video.title.text %></p>
                            </a>
                            <a href="<%= (video.author?.id && video.author.id !== 'N/A') ? '/wkt/c/' + video.author.id : '/wkt/watch/' + video.id %>" class="text-gray-400 text-xs hover:text-white transition mb-0.5 block truncate"><%= video.author.name %></a>
                            <p class="text-gray-500 text-xs"><%= video.view_count?.text || video.short_view_count?.text %> • <%= video.published?.text || "" %></p>
                        </div>
                    </div>
                </div>
              <% } else if (video.type.endsWith("Playlist")) { %>
                <div class="result-item bg-gray-600 p-4 rounded">
                  <a href="/wkt/p/<%= video.id %>">
                    <img src="/vi/<%= video?.endpoint?.payload?.videoId || video.first_videos[0]?.id %>/mqdefault.jpg" alt="<%= video.title.text %>" class="w-full h-auto rounded">
                  </a>
                    <div class="mt-2">
                        <p class="text-sm text-gray-400"><a href="/wkt/u/<%= video.author.id %>"><%= video.author.name %></a></p>
                        <p class="text-lg font-bold">プレイリスト(<%= video.video_count?.text %>本以上の動画)</p>
                    </div>
                </div>
              <% } else if (video.type.endsWith("Channel")) { %>
                <div class="result-item bg-gray-600 p-4 rounded">
                  <a href="/wkt/c/<%= video.author.id %>">
                    <img src="<%= video.author.thumbnails[0].url %>" alt="<%= video.author.name %>" class="w-full h-auto rounded">
                  </a>
                    <div class="mt-2">
                        <p class="text-lg font-bold"><%= video.author.name %></p>
                        <p class="text-sm text-gray-400"><%= video.description_snippet?.text %></p>
                        <p class="text-xs text-gray-500"><%= video.subscriber_count?.text %> • <%= video.videos?.text || video.video_count?.text %></p>
                    </div>
                </div>
              <% } %>
            <% }); %>
        </div>
        
        <div class="flex justify-center mt-10 mb-6">
            <a class="px-6 py-3 bg-blue-600 text-white text-lg font-semibold rounded-full shadow-md hover:bg-blue-700 transition"
               href="/wkt/ss?q=<%= query %>&p=<%= page+1 %>">
              もっと読み込む
            </a>
        </div>

        <div style="height:480px;" class="w-full max-w-3xl mx-auto mt-8">
            <script src="//accaii.com/wktplus/widget.js" async></script>
        </div>

    </div>
  
<script>
window.addEventListener("load", function() {
  const query = '<%= query %>';
  if (query) {
      updateSearchHistory(query);
  }
});
  
const searchBox = document.getElementById('searchbox');
const clearBtn = document.getElementById('clearBtn');
function toggleClearButton() {
    clearBtn.style.display = searchBox.value ? 'block' : 'none';
}
searchBox.addEventListener('input', toggleClearButton);
clearBtn.addEventListener('click', () => {
   searchBox.value = '';
   searchBox.focus();
   toggleClearButton();
});
toggleClearButton();
  
function updateSearchHistory(query) {
    let history = JSON.parse(localStorage.getItem('searchHistory')) || [];
    history = history.filter(item => item !== query);
    history.unshift(query);
    if (history.length > 16) {
        history = history.slice(0, 16);
   }
   localStorage.setItem('searchHistory', JSON.stringify(history));
}
</script>
</body>
</html>
