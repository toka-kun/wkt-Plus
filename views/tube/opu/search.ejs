<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= res.correctedQuery %> - 検索</title>
    <link rel="stylesheet" href="/css/page.css">
    <script src="/js/tailwindcss.js"></script>
    <link rel="stylesheet" href="https://code.jquery.com/ui/1.12.1/themes/base/jquery-ui.css">
    <script src="https://code.jquery.com/jquery-3.5.1.js"></script>
    <script src="https://code.jquery.com/ui/1.12.1/jquery-ui.js"></script>
    <script src="/js/tube.js"></script>
</head>
<body class="bg-gray-900 text-white">
    <header class="bg-gray-800 p-4 flex justify-between items-center fixed top-0 left-0 w-full z-10">
        <form action="/wkt/s" method="get" class="w-1/2 relative" id="searchForm">
            <input type="text" name="q" id="searchbox" placeholder="検索" value="<%= query %>" class="searchbox w-full p-2 pr-10 rounded bg-gray-700 text-white">
            <button type="button" id="clearBtn" class="absolute right-2 top-1/2 -translate-y-1/2 flex items-center justify-center h-6 w-6 rounded-full hover:bg-gray-400 text-white text-lg leading-none hidden">
             ×
            </button>
        </form>
        <nav class="space-x-4">
            <a href="/wkt" class="text-gray-300 hover:text-white">ホーム</a>
            <a href="/wkt/trend" class="text-gray-300 hover:text-white">トレンド</a>
            <a href="/wkt/cl/fav" class="text-gray-300 hover:text-white">お気に入り</a>
            <a href="/wkt/cl/history" class="text-gray-300 hover:text-white">再生履歴</a>
        </nav>
    </header>
  
   <div class="container mx-auto p-4 mt-20">
        <% const videoCount = res.items.filter(v => v.type === 'video').length; %>
        <h2 class="text-xl font-bold mb-4">検索結果: <%= res.correctedQuery %> <span class="text-gray-400 text-base font-normal">(<%= videoCount %>件)</span></h2>
        
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
            <% res.items.forEach(function(video) { %>
               <% if (video.type === 'video') { %>
                <div class="result-item bg-gray-800 p-4 rounded-lg shadow hover:bg-gray-700 transition duration-200">
                    <a href="/wkt/watch/<%= video.id %>" class="block relative group">
                        <img loading="lazy" src="/wkt/back/vi/<%= video.id %>/mqdefault.jpg" alt="<%= video.title %>" class="w-full h-auto rounded aspect-video object-cover">
                        <% if (video.duration) { %>
                        <span class="absolute bottom-1 right-1 bg-black bg-opacity-80 text-white text-xs px-1.5 py-0.5 rounded font-medium"><%= video.duration %></span>
                        <% } %>
                        <div class="absolute inset-0 bg-black bg-opacity-0 group-hover:bg-opacity-10 transition rounded"></div>
                    </a>
                    <div class="mt-3 flex items-start space-x-3">
                        <% if (video.author?.bestAvatar?.url) { %>
                        <a href="<%= video.author?.channelID ? '/wkt/c/' + video.author.channelID : '/wkt/watch/' + video.id %>" class="flex-shrink-0">
                            <img src="<%= video.author.bestAvatar.url %>" alt="<%= video.author.name %>" class="w-9 h-9 rounded-full object-cover bg-gray-600 border border-gray-700">
                        </a>
                        <% } %>
                        <div class="flex-1 min-w-0">
                            <a href="/wkt/watch/<%= video.id %>">
                                <p class="text-white font-bold text-sm leading-snug line-clamp-2 mb-1 hover:text-blue-400 transition"><%= video.title %></p>
                            </a>
                            <a href="<%= video.author?.channelID ? '/wkt/c/' + video.author.channelID : '/wkt/watch/' + video.id %>" class="text-gray-400 text-xs hover:text-white transition mb-0.5 block truncate"><%= video.author?.name || '' %></a>
                            <p class="text-gray-500 text-xs"><%= video.views ? video.views + '回視聴' : '' %><% if (video.uploadedAt) { %> • <%= video.uploadedAt %><% } %></p>
                        </div>
                    </div>
                </div>
              <% } else if (video.type === 'playlist') { %>
                <div class="result-item bg-gray-600 p-4 rounded">
                  <a href="/wkt/p/<%= video.playlistID %>">
                    <img src="<%= video.firstVideo.bestThumbnail.url.slice(19) %>" alt="<%= video.title %>" class="w-full h-48 rounded">
                  </a>
                    <div class="mt-2">
                        <p class="text-sm text-gray-400"><a href="/wkt/u/<%= video.owner.id %>"><%= video.owner.name %></a></p>
                        <p class="text-lg font-bold">プレイリスト(<%= video.length %>本以上の動画)</p>
                    </div>
                </div>
              <% } else if (video.type === 'channel') { %>
                <div class="result-item bg-gray-600 p-4 rounded">
                  <a href="/wkt/c/<%= video.channelID %>">
                    <img src="<%= video.bestAvatar.url %>" alt="<%= video.name %>" class="w-full h-auto rounded">
                  </a>
                    <div class="mt-2">
                        <p class="text-lg font-bold"><%= video.name %></p>
                        <p class="text-sm text-gray-400"><%= video.description || video.descriptionShort %></p>
                        <p class="text-xs text-gray-500"><%= video.subscribers %> 登録</p>
                    </div>
                </div>
              <% } %>
            <% }); %>
        </div>
      <div class="flex justify-center mt-10 mb-6">
        <a class="px-6 py-3 bg-blue-600 text-white text-lg font-semibold rounded-full shadow-md hover:bg-blue-700 transition"
           href="/wkt/ss?q=<%= query %>&p=<%= page+1 %>">
          もっと読み込む
        </a>
      </div>
    </div>
<script>
window.addEventListener("load", function() {
  const query = '<%= query %>';
  if (query) {
      updateSearchHistory(query);
  }
});

const searchBox = document.getElementById('searchbox');
const clearBtn = document.getElementById('clearBtn');
function toggleClearButton() {
    clearBtn.style.display = searchBox.value ? 'block' : 'none';
}
searchBox.addEventListener('input', toggleClearButton);
clearBtn.addEventListener('click', () => {
   searchBox.value = '';
   searchBox.focus();
   toggleClearButton();
});
toggleClearButton();

function updateSearchHistory(query) {
    let history = JSON.parse(localStorage.getItem('searchHistory')) || [];
    history = history.filter(item => item !== query);
    history.unshift(query);
    if (history.length > 16) {
        history = history.slice(0, 16);
   }
   localStorage.setItem('searchHistory', JSON.stringify(history));
}
</script>
</body>
</html>
