    <script>
        // タブ切り替えロジック
        const tabPopular = document.getElementById("tab-popular");
        const tabAu = document.getElementById("tab-au");
        const tabOnline = document.getElementById("tab-online");

        const containerPopular = document.getElementById("popular-container");
        const containerAu = document.getElementById("au-container");
        const containerOnline = document.getElementById("online-container");

        const tabs = [
            { btn: tabPopular, container: containerPopular, activeColor: "border-blue-500" },
            { btn: tabAu, container: containerAu, activeColor: "border-red-500" },
            { btn: tabOnline, container: containerOnline, activeColor: "border-green-500" }
        ];

        function switchTab(selectedBtn) {
            tabs.forEach(tab => {
                if (tab.btn === selectedBtn) {
                    tab.btn.classList.add("text-white", "border-b-2", tab.activeColor);
                    tab.btn.classList.remove("text-gray-400");
                    tab.container.classList.remove("hidden");
                } else {
                    tab.btn.classList.remove("text-white", "border-b-2", tab.activeColor);
                    tab.btn.classList.add("text-gray-400");
                    tab.container.classList.add("hidden");
                }
            });
        }

        tabPopular.addEventListener("click", () => switchTab(tabPopular));
        tabAu.addEventListener("click", () => switchTab(tabAu));
        tabOnline.addEventListener("click", () => switchTab(tabOnline));

        // 検索ロジック
        const searchInput = document.getElementById('search');
        const tools = document.querySelectorAll('.app-card');

        searchInput.addEventListener('input', function() {
            const searchText = searchInput.value.toLowerCase();

            tools.forEach(tool => {
                const title = tool.querySelector('.app-title').textContent.toLowerCase();
                const description = tool.querySelector('.app-description').textContent.toLowerCase();
                if (title.includes(searchText) || description.includes(searchText)) {
                    tool.style.display = '';
                } else {
                    tool.style.display = 'none';
                }
            });
        });
    </script>

